    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: anexo-mapeo\n",
        "#| code-summary: Column→meaning harmonization table (EBF, A0200002)\n",
        "#| tbl-cap: Columns of code A0200002 (EBF) used by year and age at check-up, according to the official DEIS dictionaries.\n",
        "filas_anexo = []\n",
        "for anio_str, info in sorted(mapeo.items()):\n",
        "    cfg = info[\"codigos\"].get(COD_LME, {})\n",
        "    fila = {\"Year\": anio_str, \"Dictionary file\": info[\"_archivo\"]}\n",
        "    for e in EDADES:\n",
        "        fila[ETIQ_EDAD[e]] = \"+\".join(cfg.get(\"edad_cols\", {}).get(e, [])) or \"—\"\n",
        "    fila[\"Indigenous\"] = \"+\".join(cfg.get(\"po_cols\", [])) or \"—\"\n",
        "    fila[\"Migrants\"] = \"+\".join(cfg.get(\"mig_cols\", [])) or \"—\"\n",
        "    filas_anexo.append(fila)\n",
        "boton_tabla(pd.DataFrame(filas_anexo).set_index(\"Year\"), \"anexo_mapeo_columnas\")"
      ],
      "id": "anexo-mapeo",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: anexo-qc\n",
        "#| code-summary: ETL QC\n",
        "#| tbl-cap: ETL quality control by year (aggregated rows and anomalies).\n",
        "boton_tabla(pd.DataFrame(qc_etl).T[[\"filas_agregadas\", \"comuna_vacia\"]].rename(\n",
        "    columns={\"filas_agregadas\": \"Aggregated rows\", \"comuna_vacia\": \"Rows without municipality\"}), \"anexo_qc_etl\")"
      ],
      "id": "anexo-qc",
