      "source": [
        "#| label: setup\n",
        "#| code-summary: Configuración, paletas y carga de datos\n",
        "import json\n",
        "import warnings\n",
        "from pathlib import Path\n",
        "\n",
        "from IPython.display import Markdown, display\n",
        "import geopandas as gpd\n",
        "import matplotlib as mpl\n",
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import libpysal\n",
        "import esda\n",
        "import spreg\n",
        "import ruptures as rpt\n",
        "import statsmodels.api as sm\n",
        "import statsmodels.formula.api as smf\n",
        "from matplotlib.colors import LinearSegmentedColormap, ListedColormap\n",
        "from statsmodels.stats.proportion import proportion_confint\n",
        "from statsmodels.tsa.seasonal import STL\n",
        "\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "np.random.seed(20260707)\n",
        "SEED = 20260707\n",
        "\n",
        "RAIZ = Path(\"..\").resolve()\n",
        "DATA = RAIZ / \"data\"\n",
        "OUT = RAIZ / \"output_files\" / \"stage4\"\n",
        "OUT.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "# --- paleta (sistema validado; ver skill de visualización) ---\n",
        "PAL = [\"#2a78d6\", \"#1baf7a\", \"#eda100\", \"#008300\",\n",
        "       \"#4a3aa7\", \"#e34948\", \"#e87ba4\", \"#eb6834\"]   # categórica, orden fijo\n",
        "SEQ_STEPS = [\"#cde2fb\", \"#9ec5f4\", \"#6da7ec\", \"#3987e5\",\n",
        "             \"#256abf\", \"#1c5cab\", \"#104281\"]          # secuencial azul claro→oscuro\n",
        "CMAP_SEQ = LinearSegmentedColormap.from_list(\"seq_azul\", SEQ_STEPS)\n",
        "CMAP_DIV = LinearSegmentedColormap.from_list(\n",
        "    \"div_azul_rojo\", [\"#104281\", \"#3987e5\", \"#f0efec\", \"#e34948\", \"#8f1f1f\"])\n",
        "INK, INK2, MUT, GRID = \"#0b0b0b\", \"#52514e\", \"#898781\", \"#e1e0d9\"\n",
        "COL_LISA = {\"HH\": \"#e34948\", \"LL\": \"#2a78d6\", \"LH\": \"#9ec5f4\",\n",
        "            \"HL\": \"#f4a9a8\", \"ns\": \"#e1e0d9\"}\n",
        "\n",
        "mpl.rcParams.update({\n",
        "    \"font.family\": \"sans-serif\", \"font.size\": 10,\n",
        "    \"axes.edgecolor\": MUT, \"axes.labelcolor\": INK2, \"axes.titlecolor\": INK,\n",
        "    \"axes.grid\": True, \"grid.color\": GRID, \"grid.linewidth\": 0.6,\n",
        "    \"xtick.color\": MUT, \"ytick.color\": MUT,\n",
        "    \"axes.spines.top\": False, \"axes.spines.right\": False,\n",
        "    \"figure.dpi\": 130, \"savefig.dpi\": 150, \"figure.facecolor\": \"white\",\n",
        "})\n",
        "\n",
        "# --- datos ---\n",
        "panel = pd.read_parquet(DATA / \"procesados\" / \"panel_lactancia.parquet\")\n",
        "mapeo = json.loads((RAIZ / \"docs\" / \"mapeo_columnas_rem.json\").read_text())\n",
        "crosswalk = json.loads((RAIZ / \"docs\" / \"crosswalk_comunas.json\").read_text())\n",
        "qc_etl = json.loads((DATA / \"procesados\" / \"panel_lactancia_qc.json\").read_text())\n",
        "\n",
        "def nota(texto):\n",
        "    \"\"\"Nota renderizada como Markdown (evita salidas de texto plano).\"\"\"\n",
        "    display(Markdown(f\"> {texto}\"))\n",
        "\n",
        "\n",
        "# --- botones de descarga -----------------------------------------------------\n",
        "import base64\n",
        "import io as _io\n",
        "from IPython.display import HTML\n",
        "\n",
        "RECURSOS = Path(\"stage4_recursos\")            # relativo a docs/ (junto al HTML)\n",
        "FIG600 = RECURSOS / \"figuras_600dpi\"\n",
        "TABLAS_DIR = RECURSOS / \"tablas\"\n",
        "FIG600.mkdir(parents=True, exist_ok=True)\n",
        "TABLAS_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "_BTN = (\"display:inline-block;margin:4px 6px 14px 0;padding:4px 12px;\"\n",
        "        \"font-size:0.8rem;border:1px solid #2a78d6;border-radius:6px;\"\n",
        "        \"color:#2a78d6;text-decoration:none;background:#fff;\")\n",
        "\n",
        "\n",
        "def boton_figura(fig, nombre, dpi=600):\n",
        "    \"\"\"Guarda la figura en PNG a alta resolución y muestra un botón de descarga.\n",
        "\n",
        "    El PNG (pesado) se sirve desde stage4_recursos/ junto al HTML; el documento\n",
        "    en sí queda autocontenido.\n",
        "    \"\"\"\n",
        "    ruta = FIG600 / f\"{nombre}.png\"\n",
        "    fig.savefig(ruta, dpi=dpi, bbox_inches=\"tight\", facecolor=\"white\")\n",
        "    display(HTML(\n",
        "        f'<a style=\"{_BTN}\" href=\"{RECURSOS.name}/figuras_600dpi/{nombre}.png\" '\n",
        "        f'download=\"{nombre}.png\">&#8681; Descargar figura (PNG {dpi} dpi)</a>'))\n",
        "\n",
        "\n",
        "def boton_tabla(df, nombre):\n",
        "    \"\"\"Muestra la tabla y un botón de descarga a Excel incrustado en el HTML.\"\"\"\n",
        "    display(df)\n",
        "    buf = _io.BytesIO()\n",
        "    df_x = df.copy()\n",
        "    df_x.to_excel(buf, sheet_name=nombre[:31], engine=\"openpyxl\")\n",
        "    (TABLAS_DIR / f\"{nombre}.xlsx\").write_bytes(buf.getvalue())\n",
        "    b64 = base64.b64encode(buf.getvalue()).decode()\n",
        "    display(HTML(\n",
        "        f'<a style=\"{_BTN}\" download=\"{nombre}.xlsx\" '\n",
        "        'href=\"data:application/vnd.openxmlformats-officedocument.'\n",
        "        f'spreadsheetml.sheet;base64,{b64}\">&#8681; Descargar tabla (Excel)</a>'))\n",
        "\n",
        "shp = gpd.read_file(DATA / \"comunas.shp\")\n",
        "shp[\"IdComuna\"] = shp[\"cod_comuna\"].astype(int).map(lambda c: f\"{c:05d}\")\n",
        "shp = shp[shp[\"codregion\"].between(1, 16)].copy()\n",
        "\n",
        "# armonización territorial: códigos antiguos -> codificación vigente\n",
        "panel = panel.dropna(subset=[\"IdComuna\"]).copy()\n",
        "panel = panel[panel[\"IdComuna\"] != \"\"]\n",
        "panel[\"IdComuna\"] = panel[\"IdComuna\"].replace(crosswalk)\n",
        "panel[\"region\"] = panel[\"IdComuna\"].str[:2].astype(int)\n",
        "\n",
        "NOMBRES_REGION = {\n",
        "    1: \"Tarapacá\", 2: \"Antofagasta\", 3: \"Atacama\", 4: \"Coquimbo\",\n",
        "    5: \"Valparaíso\", 6: \"O'Higgins\", 7: \"Maule\", 8: \"Biobío\",\n",
        "    9: \"La Araucanía\", 10: \"Los Lagos\", 11: \"Aysén\", 12: \"Magallanes\",\n",
        "    13: \"Metropolitana\", 14: \"Los Ríos\", 15: \"Arica y Parinacota\", 16: \"Ñuble\",\n",
        "}\n",
        "COD_DEN, COD_LME, COD_LMC = \"A0200001\", \"A0200002\", \"A0200003\"\n",
        "EDADES = [\"1m\", \"3m\", \"6m\", \"12m\", \"24m\"]\n",
        "ETIQ_EDAD = {\"1m\": \"1.er mes\", \"3m\": \"3.er mes\", \"6m\": \"6.º mes\",\n",
        "             \"12m\": \"12.º mes\", \"24m\": \"24.º mes\"}\n",
        "ULTIMO_COMPLETO = 2024   # último año con cobertura comunal completa y datos consolidados\n",
        "                         # (2025 aún en consolidación en DEIS: ~274/337 comunas; 2026 preliminar)\n",
        "\n",
        "nota(f\"**Panel de entrada**: {len(panel):,} filas | comunas vigentes: \"\n",
        "     f\"{panel['IdComuna'].nunique()} | shapefile: {len(shp)} comunas.\")"
      ],
      "id": "setup",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: armonizacion\n",
        "#| code-summary: 'Armonización: columnas crudas → indicadores por edad de control'\n",
        "def sumar_cols(df, cols):\n",
        "    presentes = [c for c in cols if c in df.columns]\n",
        "    return df[presentes].sum(axis=1) if presentes else pd.Series(0.0, index=df.index)\n",
        "\n",
        "registros = []\n",
        "for anio_str, info in mapeo.items():\n",
        "    anio = int(anio_str)\n",
        "    sub = panel[panel[\"Ano\"] == anio]\n",
        "    if sub.empty:\n",
        "        continue\n",
        "    for codigo, cfg in info[\"codigos\"].items():\n",
        "        s = sub[sub[\"CodigoPrestacion\"] == codigo]\n",
        "        if s.empty:\n",
        "            continue\n",
        "        base = s[[\"Ano\", \"Mes\", \"IdComuna\", \"region\", \"n_establecimientos\"]].copy()\n",
        "        for edad, cols in cfg[\"edad_cols\"].items():\n",
        "            base[edad] = sumar_cols(s, cols)\n",
        "        for extra, key in [(\"po_cols\", \"po\"), (\"mig_cols\", \"mig\"), (\"total_cols\", \"total\")]:\n",
        "            if cfg.get(extra):\n",
        "                base[key] = sumar_cols(s, cfg[extra])\n",
        "        # díadas neonatales (era IV): ≤10 días y 11–28 días de vida\n",
        "        for dkey, dcols in cfg.get(\"diada_cols\", {}).items():\n",
        "            base[dkey] = sumar_cols(s, dcols)\n",
        "        # sexo (era III)\n",
        "        for sexo in (\"H\", \"M\"):\n",
        "            for edad, cols in cfg.get(\"sexo_cols\", {}).get(sexo, {}).items():\n",
        "                base[f\"{edad}_{sexo}\"] = sumar_cols(s, cols)\n",
        "        base[\"codigo\"] = codigo\n",
        "        registros.append(base)\n",
        "\n",
        "arm = pd.concat(registros, ignore_index=True)\n",
        "\n",
        "def tabla_indicador(codigo, columnas):\n",
        "    \"\"\"Suma anual (o mensual) por comuna para un código y columnas dadas.\"\"\"\n",
        "    t = arm[arm[\"codigo\"] == codigo]\n",
        "    return t.groupby([\"Ano\", \"Mes\", \"IdComuna\", \"region\"])[columnas].sum().reset_index()\n",
        "\n",
        "cols_num = [c for c in arm.columns if c not in\n",
        "            (\"Ano\", \"Mes\", \"IdComuna\", \"region\", \"codigo\", \"n_establecimientos\")]\n",
        "den = tabla_indicador(COD_DEN, cols_num).rename(columns={c: f\"den_{c}\" for c in cols_num})\n",
        "num = tabla_indicador(COD_LME, cols_num).rename(columns={c: f\"lme_{c}\" for c in cols_num})\n",
        "lmc = tabla_indicador(COD_LMC, cols_num).rename(columns={c: f\"lmc_{c}\" for c in cols_num})\n",
        "\n",
        "cm = (den.merge(num, on=[\"Ano\", \"Mes\", \"IdComuna\", \"region\"], how=\"outer\")\n",
        "         .merge(lmc, on=[\"Ano\", \"Mes\", \"IdComuna\", \"region\"], how=\"outer\")\n",
        "         .fillna(0.0))\n",
        "\n",
        "# QC de consistencia: el numerador no puede exceder al denominador. En los datos\n",
        "# crudos existen violaciones aisladas (errores de digitación de establecimientos);\n",
        "# se truncan al denominador (num := min(num, den)) y se reporta la magnitud.\n",
        "recortes = 0\n",
        "for c in cols_num:\n",
        "    denc = f\"den_{c}\"\n",
        "    for pref in (\"lme\", \"lmc\"):\n",
        "        col = f\"{pref}_{c}\"\n",
        "        if col in cm.columns:\n",
        "            exceso = cm[col] > cm[denc]\n",
        "            recortes += int(exceso.sum())\n",
        "            cm.loc[exceso, col] = cm.loc[exceso, denc]\n",
        "nota(f\"**Panel armonizado comuna-mes**: {len(cm):,} filas, \"\n",
        "     f\"{cm['IdComuna'].nunique()} comunas, {cm['Ano'].min()}–{cm['Ano'].max()}. \"\n",
        "     f\"Celdas comuna-mes truncadas por numerador > denominador: **{recortes:,}** \"\n",
        "     f\"(error de registro en origen; ver Limitaciones).\")"
      ],
      "id": "armonizacion",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Control de calidad y cobertura {#sec-qc}"
      ],
      "id": "20507792"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: qc\n",
        "#| code-summary: Cobertura del panel por año\n",
        "#| tbl-cap: 'Cobertura de la serie: comunas informantes, controles al 6.º mes y meses disponibles'\n",
        "qc = (cm.groupby(\"Ano\")\n",
        "        .agg(comunas=(\"IdComuna\", \"nunique\"),\n",
        "             meses=(\"Mes\", \"nunique\"),\n",
        "             controles_6m=(\"den_6m\", \"sum\"),\n",
        "             lme_6m=(\"lme_6m\", \"sum\"))\n",
        "        .assign(prev_lme6=lambda d: 100 * d[\"lme_6m\"] / d[\"controles_6m\"])\n",
        "        .round(1))\n",
        "qc[\"nota\"] = \"\"\n",
        "qc.loc[2025, \"nota\"] = \"en consolidación (cobertura comunal parcial)\"\n",
        "qc.loc[2026, \"nota\"] = \"preliminar (año en curso)\"\n",
        "qc.columns = [\"Comunas\", \"Meses\", \"Controles 6.º mes\", \"LME 6.º mes\", \"LME₆ (%)\", \"Nota\"]\n",
        "boton_tabla(qc, \"cobertura_anual\")"
      ],
      "id": "qc",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "La cobertura comunal es de ~302 comunas informantes en 2009 y se estabiliza en\n",
        "~337–341 desde 2010 **hasta 2024**; en 2025 cae la cantidad de comunas informantes\n",
        "porque el DEIS aún consolida ese año, y 2026 es preliminar. Por ello la inferencia se\n",
        "restringe a 2009–2024 (y el modelo de panel usa 2010 como año de referencia, primer\n",
        "año de cobertura completa). Adicionalmente, un pequeño número de celdas comuna-mes\n",
        "presenta numeradores mayores que su denominador (error de registro en origen); esas\n",
        "celdas se truncan al denominador y su recuento se reporta en el chunk de\n",
        "armonización.\n",
        "\n",
        "# Serie nacional 2009–2026\n",
        "\n",
        "## Prevalencia anual por edad de control"
      ],
      "id": "33b9874f"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-nacional-anual\n",
        "#| code-summary: Serie nacional anual con IC de Wilson\n",
        "#| fig-cap: 'Prevalencia nacional de lactancia materna exclusiva según edad de control, 2009–2026. Bandas: IC 95 % de Wilson (imperceptibles por el tamaño muestral). Zona sombreada: 2025 (en consolidación) y 2026 (preliminar). Se omiten el 12.º y 24.º mes, donde la LME es ≈0 por definición (la alimentación complementaria comienza a los 6 meses).'\n",
        "nac = cm.groupby(\"Ano\")[[f\"lme_{e}\" for e in EDADES] + [f\"den_{e}\" for e in EDADES]].sum()\n",
        "EDADES_FIG = [\"1m\", \"3m\", \"6m\"]  # 12m/24m: LME ≈ 0 por definición\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 5.2))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "for i, e in enumerate(EDADES_FIG):\n",
        "    n, d = nac[f\"lme_{e}\"], nac[f\"den_{e}\"]\n",
        "    validos = d > 0\n",
        "    p = 100 * n[validos] / d[validos]\n",
        "    lo, hi = proportion_confint(n[validos], d[validos], method=\"wilson\")\n",
        "    ax.plot(p.index, p.values, color=PAL[i], lw=2, marker=\"o\", ms=4,\n",
        "            label=ETIQ_EDAD[e])\n",
        "    ax.fill_between(p.index, 100 * lo, 100 * hi, color=PAL[i], alpha=0.15, lw=0)\n",
        "    ax.annotate(ETIQ_EDAD[e], (p.index[-1], p.values[-1]),\n",
        "                xytext=(6, 0), textcoords=\"offset points\",\n",
        "                color=PAL[i], fontsize=9, va=\"center\")\n",
        "ax.axvspan(2024.5, 2026.5, color=GRID, alpha=0.35, zorder=0)\n",
        "ax.set_xlim(2008.5, 2027.6)\n",
        "ax.set_ylabel(\"LME (% de niños controlados)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Lactancia materna exclusiva en Chile por edad de control, 2009–2026\")\n",
        "ax.legend(loc=\"upper right\", frameon=False, ncols=2)\n",
        "plt.tight_layout()\n",
        "nac_pct = pd.DataFrame({e: 100 * nac[f\"lme_{e}\"] / nac[f\"den_{e}\"].replace(0, np.nan)\n",
        "                        for e in EDADES}).round(2)\n",
        "nac_pct.to_csv(OUT / \"lme_nacional_anual.csv\")\n",
        "plt.show()\n",
        "boton_figura(fig, \"nacional_anual\")"
      ],
      "id": "fig-nacional-anual",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Lactancia materna continuada al año y a los dos años (aproximación al indicador OMS)\n",
        "\n",
        "La LME solo es un objetivo hasta el 6.º mes; a partir de entonces el indicador de\n",
        "referencia de la OMS es la **lactancia materna continuada** junto a la alimentación\n",
        "complementaria. Se define aquí como (A0200002 + A0200003) ÷ A0200001 en el control del\n",
        "12.º mes (serie completa) y del 24.º mes (disponible desde 2014). Esta definición\n",
        "excluye a los niños con lactancia mixta con fórmula y es por tanto una **cota\n",
        "inferior**, pero **no es comparable a través de 2021**: ese año el formulario creó la\n",
        "categoría LM + fórmula + complementaria (03600140) y parte de los niños antes anotados\n",
        "en A0200003 migró a ella — la caída post-2021 de la serie «sin fórmula» es en gran\n",
        "medida re-codificación, como lo demuestra la estabilidad de la versión **ampliada**\n",
        "(que incorpora los códigos con fórmula, disponible desde 2021). La medida se calcula\n",
        "sobre niños controlados del sistema público, por lo que es una aproximación al\n",
        "indicador OMS, no una estimación poblacional."
      ],
      "id": "ca15b6a1"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-continuada\n",
        "#| code-summary: Lactancia continuada al 12.º y 24.º mes\n",
        "#| fig-cap: 'Lactancia materna continuada (sin fórmula) al 12.º mes (2009–2026) y al 24.º mes (2014–2026), y versión ampliada con códigos de lactancia mixta (2021+). Las series «sin fórmula» NO son comparables a través de 2021 (línea punteada): la creación de la categoría LM+fórmula+complementaria re-codificó parte de A0200003. Zona sombreada: 2025 en consolidación y 2026 preliminar.'\n",
        "lc = cm.groupby(\"Ano\")[[\"lme_12m\", \"lmc_12m\", \"den_12m\",\n",
        "                        \"lme_24m\", \"lmc_24m\", \"den_24m\"]].sum()\n",
        "lc12 = 100 * (lc[\"lme_12m\"] + lc[\"lmc_12m\"]) / lc[\"den_12m\"]\n",
        "lc24 = (100 * (lc[\"lme_24m\"] + lc[\"lmc_24m\"])\n",
        "        / lc[\"den_24m\"].replace(0, np.nan)).dropna()\n",
        "\n",
        "# versión ampliada 2021+: incluye LM/fórmula (03500359) y LM/fórmula/sólidos (03600140)\n",
        "mix = {}\n",
        "for cod in (\"03500359\", \"03600140\"):\n",
        "    t = arm[arm[\"codigo\"] == cod].groupby(\"Ano\")[[\"12m\"]].sum()\n",
        "    mix[cod] = t[\"12m\"]\n",
        "mix_df = pd.DataFrame(mix).reindex(lc.index).fillna(0)\n",
        "lc12_amp = (100 * (lc[\"lme_12m\"] + lc[\"lmc_12m\"] + mix_df.sum(axis=1))\n",
        "            / lc[\"den_12m\"]).loc[2021:]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 4.8))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "ax.plot(lc12.index, lc12.values, color=PAL[0], lw=2, marker=\"o\", ms=4,\n",
        "        label=\"12.º mes (sin fórmula)\")\n",
        "ax.plot(lc24.index, lc24.values, color=PAL[1], lw=2, marker=\"s\", ms=4,\n",
        "        label=\"24.º mes (sin fórmula)\")\n",
        "ax.plot(lc12_amp.index, lc12_amp.values, color=PAL[0], lw=1.6, ls=\"--\", marker=\"o\",\n",
        "        ms=3, label=\"12.º mes (incl. mixta, 2021+)\")\n",
        "ax.axvline(2021, color=INK2, lw=1, ls=\":\")\n",
        "ax.annotate(\"cambio de formulario\", (2021, ax.get_ylim()[1] * 0.97), color=INK2,\n",
        "            fontsize=8, ha=\"center\", va=\"top\")\n",
        "ax.axvspan(2024.5, 2026.5, color=GRID, alpha=0.35, zorder=0)\n",
        "ax.set_ylabel(\"Lactancia continuada (% de controlados)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Lactancia materna continuada al año y a los dos años, 2009–2026\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"continuada\")\n",
        "pd.DataFrame({\"LC_12m\": lc12, \"LC_24m\": lc24, \"LC_12m_ampliada\": lc12_amp}\n",
        "             ).round(2).to_csv(OUT / \"lactancia_continuada_nacional.csv\")"
      ],
      "id": "fig-continuada",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Retención de la LME entre el 1.er y el 6.º mes"
      ],
      "id": "ef0a97cb"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-retencion\n",
        "#| code-summary: Retención nacional LME 1.er → 6.º mes\n",
        "#| fig-cap: 'Retención de la LME: razón entre la prevalencia al 3.er/6.º mes y la del 1.er mes, por año. Un valor de 0,8 al 6.º mes indica que se conserva el 80 % de la prevalencia inicial. Zona sombreada: años provisionales.'\n",
        "ret_nac = pd.DataFrame({\n",
        "    e: 100 * nac[f\"lme_{e}\"] / nac[f\"den_{e}\"] for e in (\"1m\", \"3m\", \"6m\")})\n",
        "ret_nac[\"ret_6_1\"] = ret_nac[\"6m\"] / ret_nac[\"1m\"]\n",
        "ret_nac[\"ret_3_1\"] = ret_nac[\"3m\"] / ret_nac[\"1m\"]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 4.4))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "ax.plot(ret_nac.index, ret_nac[\"ret_3_1\"], color=PAL[1], lw=2, marker=\"s\", ms=4,\n",
        "        label=\"3.er/1.er mes\")\n",
        "ax.plot(ret_nac.index, ret_nac[\"ret_6_1\"], color=PAL[0], lw=2, marker=\"o\", ms=4,\n",
        "        label=\"6.º/1.er mes\")\n",
        "ax.axvspan(2024.5, 2026.5, color=GRID, alpha=0.35, zorder=0)\n",
        "ax.set_ylabel(\"Razón de retención de la LME\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Retención de la LME a lo largo de los controles, 2009–2026\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"retencion\")\n",
        "nota(f\"La razón 6.º/1.er mes compara **niños distintos** en cada control (cohorte \"\n",
        "     \"sintética, no seguimiento individual). Pasó de \"\n",
        "     f\"{ret_nac['ret_6_1'].loc[2009]:.2f} (2009) a \"\n",
        "     f\"{ret_nac['ret_6_1'].loc[2019]:.2f} (2019) y \"\n",
        "     f\"{ret_nac['ret_6_1'].loc[ULTIMO_COMPLETO]:.2f} ({ULTIMO_COMPLETO}). El salto se \"\n",
        "     \"concentra en el quiebre de registro de 2015, por lo que parte del aumento es \"\n",
        "     \"atribuible al cambio de formulario y no solo a mejor mantención. Tras 2019 la \"\n",
        "     \"retención se mantiene alta mientras el **nivel inicial** (LME al 1.er mes) \"\n",
        "     \"sigue descendiendo: el problema reciente está en el inicio de la LME, no en su \"\n",
        "     \"mantención.\")"
      ],
      "id": "fig-retencion",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Estacionalidad, tendencia y puntos de quiebre"
      ],
      "id": "de644f3c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-stl\n",
        "#| code-summary: 'Serie mensual LME al 6.º mes: STL y quiebres estructurales (PELT)'\n",
        "#| fig-cap: 'Serie mensual nacional de LME al 6.º mes: descomposición STL (tendencia y estacionalidad) y puntos de quiebre detectados por PELT sobre la serie desestacionalizada (líneas verticales). Serie 2009–2024 (2025 en consolidación y 2026 preliminar se excluyen).'\n",
        "mens = (cm[cm[\"Ano\"] <= ULTIMO_COMPLETO]\n",
        "        .groupby([\"Ano\", \"Mes\"])[[\"lme_6m\", \"den_6m\"]].sum().reset_index())\n",
        "mens[\"fecha\"] = pd.to_datetime(dict(year=mens[\"Ano\"], month=mens[\"Mes\"], day=1))\n",
        "mens = mens.set_index(\"fecha\").sort_index()\n",
        "mens[\"p6\"] = 100 * mens[\"lme_6m\"] / mens[\"den_6m\"]\n",
        "\n",
        "stl = STL(mens[\"p6\"], period=12, robust=True).fit()\n",
        "desest = mens[\"p6\"] - stl.seasonal\n",
        "\n",
        "# PELT con jump=1 (resolución mensual); el quiebre se fecha en el PRIMER mes del\n",
        "# nuevo régimen. Sensibilidad a la penalización: se reportan pen = k·log(n), k=1..3.\n",
        "algo = rpt.Pelt(model=\"rbf\", jump=1).fit(desest.values.reshape(-1, 1))\n",
        "sens_pen = {}\n",
        "for k in (1, 2, 3):\n",
        "    b = algo.predict(pen=k * np.log(len(desest)))\n",
        "    sens_pen[k] = [desest.index[i].strftime(\"%Y-%m\") for i in b[:-1]]\n",
        "bkps = algo.predict(pen=3 * np.log(len(desest)))\n",
        "fechas_quiebre = [desest.index[i] for i in bkps[:-1]]\n",
        "\n",
        "fig, axes = plt.subplots(3, 1, figsize=(9.5, 7.5), sharex=True,\n",
        "                         gridspec_kw={\"height_ratios\": [2, 1, 1]})\n",
        "axes[0].plot(mens.index, mens[\"p6\"], color=GRID, lw=1, label=\"Observada\")\n",
        "axes[0].plot(stl.trend.index, stl.trend, color=PAL[0], lw=2.2, label=\"Tendencia STL\")\n",
        "for f in fechas_quiebre:\n",
        "    axes[0].axvline(f, color=PAL[5], lw=1.2, ls=\"--\")\n",
        "    axes[0].annotate(f.strftime(\"%Y-%m\"), (f, axes[0].get_ylim()[1]),\n",
        "                     xytext=(3, -12), textcoords=\"offset points\",\n",
        "                     color=PAL[5], fontsize=8)\n",
        "axes[0].set_ylabel(\"LME₆ (%)\")\n",
        "axes[0].legend(frameon=False, loc=\"lower left\")\n",
        "axes[0].set_title(\"LME al 6.º mes: serie mensual, tendencia y quiebres estructurales\")\n",
        "axes[1].plot(stl.seasonal.index, stl.seasonal, color=PAL[1], lw=1.2)\n",
        "axes[1].set_ylabel(\"Estacional\")\n",
        "axes[2].plot(stl.resid.index, stl.resid, color=MUT, lw=0.8)\n",
        "axes[2].set_ylabel(\"Resto\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"stl\")\n",
        "sens_txt = \"; \".join(f\"pen = {k}·log(n): {', '.join(v) if v else 'ninguno'}\"\n",
        "                     for k, v in sens_pen.items())\n",
        "nota(f\"**Quiebres detectados** (pen = 3·log n): \"\n",
        "     f\"{', '.join(f.strftime('%Y-%m') for f in fechas_quiebre)}. \"\n",
        "     f\"Sensibilidad — {sens_txt}. El quiebre de 2015 es robusto a la penalización; \"\n",
        "     f\"los de 2017 y fines de 2020 solo aparecen con la penalización más laxa.\")"
      ],
      "id": "fig-stl",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Efecto de la pandemia: análisis de series interrumpidas"
      ],
      "id": "5c73422b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: its\n",
        "#| code-summary: ITS con errores Newey–West\n",
        "# ventana: régimen post-quiebre estructural (2015-01) hasta 2024-12\n",
        "its = mens.loc[\"2015-01-01\":].reset_index().copy()\n",
        "its[\"t\"] = np.arange(len(its))\n",
        "t0 = int(its.index[its[\"fecha\"] == \"2020-03-01\"][0])\n",
        "its[\"covid\"] = (its[\"t\"] >= t0).astype(int)\n",
        "its[\"t_post\"] = (its[\"t\"] - t0).clip(lower=0)\n",
        "for k in (1, 2):\n",
        "    its[f\"sin{k}\"] = np.sin(2 * np.pi * k * its[\"t\"] / 12)\n",
        "    its[f\"cos{k}\"] = np.cos(2 * np.pi * k * its[\"t\"] / 12)\n",
        "\n",
        "X = sm.add_constant(its[[\"t\", \"covid\", \"t_post\", \"sin1\", \"cos1\", \"sin2\", \"cos2\"]])\n",
        "mod_its = sm.OLS(its[\"p6\"], X).fit(cov_type=\"HAC\", cov_kwds={\"maxlags\": 12})\n",
        "\n",
        "res_its = pd.DataFrame({\n",
        "    \"Coeficiente\": mod_its.params, \"EE (NW)\": mod_its.bse,\n",
        "    \"IC 2.5 %\": mod_its.conf_int()[0], \"IC 97.5 %\": mod_its.conf_int()[1],\n",
        "    \"p\": mod_its.pvalues,\n",
        "}).loc[[\"const\", \"t\", \"covid\", \"t_post\"]].round(3)\n",
        "res_its.index = [\"Nivel basal (%)\", \"Tendencia pre 2015–feb2020 (pp/mes)\",\n",
        "                 \"Cambio de nivel COVID (pp)\", \"Cambio de pendiente COVID (pp/mes)\"]\n",
        "boton_tabla(res_its, \"its_lme6\")"
      ],
      "id": "its",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-its\n",
        "#| code-summary: Observado vs. contrafactual\n",
        "#| fig-cap: 'Análisis de series interrumpidas sobre el régimen post-quiebre (enero 2015–diciembre 2024): LME al 6.º mes observada y contrafactual (proyección del régimen enero 2015–febrero 2020). Errores Newey–West (12 rezagos). El contrafactual es una extrapolación lineal y debe leerse con cautela creciente a mayor horizonte.'\n",
        "X_cf = X.copy()\n",
        "X_cf[[\"covid\", \"t_post\"]] = 0\n",
        "pred_cf = mod_its.predict(X_cf)\n",
        "pred_obs = mod_its.predict(X)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 4.8))\n",
        "ax.plot(its[\"fecha\"], its[\"p6\"], color=GRID, lw=1, label=\"Observada\")\n",
        "ax.plot(its[\"fecha\"], pred_obs, color=PAL[0], lw=2, label=\"Ajuste ITS\")\n",
        "ax.plot(its[\"fecha\"][t0:], pred_cf[t0:], color=PAL[5], lw=2, ls=\"--\",\n",
        "        label=\"Contrafactual sin COVID\")\n",
        "ax.axvline(its[\"fecha\"][t0], color=MUT, lw=1, ls=\":\")\n",
        "ax.annotate(\"mar-2020\", (its[\"fecha\"][t0], ax.get_ylim()[0]),\n",
        "            xytext=(4, 6), textcoords=\"offset points\", color=MUT, fontsize=9)\n",
        "ax.set_ylabel(\"LME₆ (%)\")\n",
        "ax.legend(frameon=False, loc=\"lower left\")\n",
        "ax.set_title(\"Impacto de la pandemia sobre la LME al 6.º mes (ITS)\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"its\")\n",
        "\n",
        "efecto_24m = (pred_obs - pred_cf).iloc[t0 + 24] if t0 + 24 < len(its) else np.nan\n",
        "nota(f\"**Brecha estimada a 24 meses** del inicio de la pandemia: **{efecto_24m:+.1f} pp**. \"\n",
        "     \"Se trata de una *interrupción asociada* a la pandemia, no interpretable como \"\n",
        "     \"efecto causal puro: el denominador de controles cayó ~37 % en 2020 \"\n",
        "     \"(selección de la subpoblación asistente).\")"
      ],
      "id": "fig-its",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Efecto de la pandemia por edad de control"
      ],
      "id": "9a30431b"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: its-edades\n",
        "#| code-summary: ITS replicado para el 1.er, 3.er y 6.º mes\n",
        "#| tbl-cap: 'Análisis de series interrumpidas por edad de control (régimen base enero 2015–febrero 2020, errores Newey–West): cambio de nivel y de pendiente asociados a la pandemia, y brecha respecto del contrafactual a 24 meses.'\n",
        "def its_por_edad(edad):\n",
        "    m = (cm[cm[\"Ano\"] <= ULTIMO_COMPLETO]\n",
        "         .groupby([\"Ano\", \"Mes\"])[[f\"lme_{edad}\", f\"den_{edad}\"]].sum().reset_index())\n",
        "    m[\"fecha\"] = pd.to_datetime(dict(year=m[\"Ano\"], month=m[\"Mes\"], day=1))\n",
        "    m = m.set_index(\"fecha\").sort_index().loc[\"2015-01-01\":]\n",
        "    m[\"p\"] = 100 * m[f\"lme_{edad}\"] / m[f\"den_{edad}\"]\n",
        "    m = m.reset_index()\n",
        "    m[\"t\"] = np.arange(len(m))\n",
        "    t0e = int(m.index[m[\"fecha\"] == \"2020-03-01\"][0])\n",
        "    m[\"covid\"] = (m[\"t\"] >= t0e).astype(int)\n",
        "    m[\"t_post\"] = (m[\"t\"] - t0e).clip(lower=0)\n",
        "    for k in (1, 2):\n",
        "        m[f\"sin{k}\"] = np.sin(2 * np.pi * k * m[\"t\"] / 12)\n",
        "        m[f\"cos{k}\"] = np.cos(2 * np.pi * k * m[\"t\"] / 12)\n",
        "    Xe = sm.add_constant(m[[\"t\", \"covid\", \"t_post\", \"sin1\", \"cos1\", \"sin2\", \"cos2\"]])\n",
        "    me = sm.OLS(m[\"p\"], Xe).fit(cov_type=\"HAC\", cov_kwds={\"maxlags\": 12})\n",
        "    Xcf = Xe.copy(); Xcf[[\"covid\", \"t_post\"]] = 0\n",
        "    pred_cf24 = me.predict(Xcf).iloc[t0e + 24]\n",
        "    brecha = (me.predict(Xe) - me.predict(Xcf)).iloc[t0e + 24]\n",
        "    ci_e = me.conf_int()\n",
        "    return {\n",
        "        \"Edad\": ETIQ_EDAD[edad],\n",
        "        \"Nivel COVID (pp)\": me.params[\"covid\"],\n",
        "        \"IC nivel\": f\"[{ci_e.loc['covid', 0]:.1f}; {ci_e.loc['covid', 1]:.1f}]\",\n",
        "        \"Pendiente COVID (pp/mes)\": me.params[\"t_post\"],\n",
        "        \"IC pendiente\": f\"[{ci_e.loc['t_post', 0]:.3f}; {ci_e.loc['t_post', 1]:.3f}]\",\n",
        "        \"Brecha a 24 meses (pp)\": brecha,\n",
        "        \"Brecha relativa (%)\": 100 * brecha / pred_cf24,\n",
        "    }\n",
        "\n",
        "its_tab = pd.DataFrame([its_por_edad(e) for e in (\"1m\", \"3m\", \"6m\")]).set_index(\"Edad\")\n",
        "boton_tabla(its_tab.round(2), \"its_por_edad\")"
      ],
      "id": "its-edades",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "La interrupción pandémica no fue homogénea por edad: la tabla permite comparar si el\n",
        "golpe se concentró en el inicio de la lactancia (1.er mes, más ligado a la atención\n",
        "perinatal) o en su mantención (6.º mes, más ligado al acompañamiento ambulatorio).\n",
        "La comparación entre edades debe leerse con cautela: los niveles basales y la\n",
        "magnitud de la caída de denominadores en 2020 difieren por edad (selección de\n",
        "asistentes distinta), por lo que la **brecha relativa** al contrafactual es la\n",
        "columna más comparable.\n",
        "\n",
        "# Trayectorias regionales y convergencia"
      ],
      "id": "72a6b4b8"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-regiones\n",
        "#| code-summary: Pequeños múltiplos regionales\n",
        "#| fig-cap: LME al 6.º mes por región, 2009–2024 (línea azul), con la trayectoria nacional de referencia (gris). Codificación territorial armonizada a 16 regiones.\n",
        "reg = (cm[cm[\"Ano\"] <= ULTIMO_COMPLETO]\n",
        "       .groupby([\"Ano\", \"region\"])[[\"lme_6m\", \"den_6m\"]].sum().reset_index())\n",
        "reg[\"p6\"] = 100 * reg[\"lme_6m\"] / reg[\"den_6m\"]\n",
        "nac_serie = (cm[cm[\"Ano\"] <= ULTIMO_COMPLETO]\n",
        "             .groupby(\"Ano\")[[\"lme_6m\", \"den_6m\"]].sum())\n",
        "nac_serie = 100 * nac_serie[\"lme_6m\"] / nac_serie[\"den_6m\"]\n",
        "\n",
        "orden_reg = [15, 1, 2, 3, 4, 5, 13, 6, 7, 16, 8, 9, 14, 10, 11, 12]  # norte→sur\n",
        "fig, axes = plt.subplots(4, 4, figsize=(11, 9), sharex=True, sharey=True)\n",
        "for ax, r in zip(axes.flat, orden_reg):\n",
        "    s = reg[reg[\"region\"] == r]\n",
        "    ax.plot(nac_serie.index, nac_serie.values, color=GRID, lw=1.4)\n",
        "    ax.plot(s[\"Ano\"], s[\"p6\"], color=PAL[0], lw=1.8)\n",
        "    ax.set_title(NOMBRES_REGION[r], fontsize=9.5, color=INK)\n",
        "    ax.grid(True, lw=0.4)\n",
        "fig.supylabel(\"LME₆ (%)\", color=INK2)\n",
        "fig.suptitle(\"Trayectorias regionales de la LME al 6.º mes, 2009–2024 (orden norte→sur)\", y=0.995)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"regiones\")"
      ],
      "id": "fig-regiones",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-convergencia\n",
        "#| code-summary: Convergencia sigma entre comunas y regiones\n",
        "#| fig-cap: 'Convergencia sigma: dispersión interanual de la LME al 6.º mes entre regiones (DE simple) y entre comunas (DE ponderada por denominador). Una pendiente negativa indica convergencia territorial.'\n",
        "def de_ponderada(x, w):\n",
        "    m = np.average(x, weights=w)\n",
        "    return np.sqrt(np.average((x - m) ** 2, weights=w))\n",
        "\n",
        "com_anual = cm.groupby([\"Ano\", \"IdComuna\"])[[\"lme_6m\", \"den_6m\"]].sum().reset_index()\n",
        "com_anual = com_anual[(com_anual[\"den_6m\"] >= 30) & (com_anual[\"Ano\"] <= ULTIMO_COMPLETO)]\n",
        "com_anual[\"p6\"] = 100 * com_anual[\"lme_6m\"] / com_anual[\"den_6m\"]\n",
        "\n",
        "sigma_com = com_anual.groupby(\"Ano\").apply(\n",
        "    lambda d: de_ponderada(d[\"p6\"], d[\"den_6m\"]), include_groups=False)\n",
        "sigma_reg = reg.groupby(\"Ano\").apply(\n",
        "    lambda d: d[\"p6\"].std(), include_groups=False)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9, 4.2))\n",
        "ax.plot(sigma_com.index, sigma_com.values, color=PAL[0], lw=2, marker=\"o\", ms=4,\n",
        "        label=\"Entre comunas (ponderada)\")\n",
        "ax.plot(sigma_reg.index, sigma_reg.values, color=PAL[1], lw=2, marker=\"s\", ms=4,\n",
        "        label=\"Entre regiones\")\n",
        "ax.set_ylabel(\"Desviación estándar de LME₆ (pp)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Convergencia sigma de la LME al 6.º mes, 2009–2024\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"convergencia\")"
      ],
      "id": "fig-convergencia",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Análisis geoespacial nacional\n",
        "\n",
        "## Tasas comunales y suavizamiento bayesiano empírico"
      ],
      "id": "bdcbc2c2"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: eb\n",
        "#| code-summary: Suavizamiento bayesiano empírico (Marshall) y unión con la geometría\n",
        "def eb_suavizar(num, den):\n",
        "    \"\"\"Estimador EB global (método de momentos de Marshall) para proporciones.\"\"\"\n",
        "    num, den = np.asarray(num, float), np.asarray(den, float)\n",
        "    p = num / den\n",
        "    m = num.sum() / den.sum()\n",
        "    s2 = np.average((p - m) ** 2, weights=den)\n",
        "    a = max(s2 - m * (1 - m) / (den.mean()), 0.0)\n",
        "    w = a / (a + m * (1 - m) / den) if a > 0 else np.zeros_like(den)\n",
        "    return w * p + (1 - w) * m\n",
        "\n",
        "def comunal_anual(anio, edad=\"6m\"):\n",
        "    d = cm[cm[\"Ano\"] == anio].groupby(\"IdComuna\")[[f\"lme_{edad}\", f\"den_{edad}\"]].sum()\n",
        "    d.columns = [\"lme_6m\", \"den_6m\"]  # nombres canónicos para el resto del pipeline\n",
        "    d = d[d[\"den_6m\"] > 0]\n",
        "    d[\"p6\"] = 100 * d[\"lme_6m\"] / d[\"den_6m\"]\n",
        "    d[\"p6_eb\"] = 100 * eb_suavizar(d[\"lme_6m\"], d[\"den_6m\"])\n",
        "    return d.reset_index()\n",
        "\n",
        "com25 = comunal_anual(ULTIMO_COMPLETO)\n",
        "gdf = shp.merge(com25, on=\"IdComuna\", how=\"left\")\n",
        "nota(f\"**{ULTIMO_COMPLETO}**: {com25.shape[0]} comunas con datos; \"\n",
        "     f\"{gdf['p6'].isna().sum()} comunas del shapefile sin datos.\")\n",
        "gdf_datos = gdf.dropna(subset=[\"p6_eb\"]).reset_index(drop=True)"
      ],
      "id": "eb",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-mapa-nacional\n",
        "#| code-summary: Mapa coroplético nacional + Región Metropolitana\n",
        "#| fig-cap: 'LME al 6.º mes por comuna (tasas suavizadas por bayes empírico), 2024. Clasificación Fisher–Jenks (6 clases), rampa secuencial de un solo tono. Panel derecho: Región Metropolitana.'\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(11.5, 10),\n",
        "                               gridspec_kw={\"width_ratios\": [1, 1.35]})\n",
        "gdf.plot(ax=ax1, column=\"p6_eb\", cmap=CMAP_SEQ, scheme=\"fisherjenks\", k=6,\n",
        "         edgecolor=\"white\", linewidth=0.15,\n",
        "         missing_kwds={\"color\": GRID, \"label\": \"Sin datos\"},\n",
        "         legend=True,\n",
        "         legend_kwds={\"title\": \"LME₆ (%) EB\", \"loc\": \"center left\",\n",
        "                      \"fontsize\": 8, \"title_fontsize\": 9, \"frameon\": False})\n",
        "ax1.set_axis_off()\n",
        "ax1.set_title(f\"Chile — LME al 6.º mes, {ULTIMO_COMPLETO}\", fontsize=11)\n",
        "\n",
        "rm = gdf[gdf[\"codregion\"] == 13]\n",
        "rm.plot(ax=ax2, column=\"p6_eb\", cmap=CMAP_SEQ, scheme=\"fisherjenks\", k=6,\n",
        "        edgecolor=\"white\", linewidth=0.4,\n",
        "        missing_kwds={\"color\": GRID})\n",
        "ax2.set_axis_off()\n",
        "ax2.set_title(\"Región Metropolitana\", fontsize=11)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"mapa_nacional\")\n",
        "(gdf_datos[[\"IdComuna\", \"Comuna\", \"Region\", \"den_6m\", \"p6\", \"p6_eb\"]]\n",
        " .to_csv(OUT / f\"lme6_comunal_{ULTIMO_COMPLETO}.csv\", index=False))"
      ],
      "id": "fig-mapa-nacional",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Autocorrelación espacial global y su evolución"
      ],
      "id": "0362b930"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: moran-evolucion\n",
        "#| code-summary: I de Moran por año (permutaciones)\n",
        "from libpysal.weights import Queen, KNN, attach_islands\n",
        "\n",
        "def pesos_para(g):\n",
        "    \"\"\"Queen con tolerancia topológica (buffer 250 m) + KNN-1 para islas reales.\"\"\"\n",
        "    gb = g.copy()\n",
        "    gb[\"geometry\"] = g.geometry.buffer(250)   # sanea huecos de digitalización\n",
        "    w = Queen.from_dataframe(gb, use_index=False, silence_warnings=True)\n",
        "    if w.islands:\n",
        "        cent = g.copy()\n",
        "        cent[\"geometry\"] = g.geometry.centroid\n",
        "        w_knn = KNN.from_dataframe(cent, k=1, silence_warnings=True)\n",
        "        w = attach_islands(w, w_knn)\n",
        "    w.transform = \"r\"\n",
        "    return w\n",
        "\n",
        "morans = []\n",
        "for anio in range(2009, ULTIMO_COMPLETO + 1):\n",
        "    d = comunal_anual(anio)\n",
        "    g = shp.merge(d, on=\"IdComuna\", how=\"inner\").reset_index(drop=True)\n",
        "    w = pesos_para(g)\n",
        "    mi = esda.Moran(g[\"p6_eb\"].values, w, permutations=999)\n",
        "    morans.append({\"Ano\": anio, \"I\": mi.I, \"p_sim\": mi.p_sim, \"EI\": mi.EI})\n",
        "morans = pd.DataFrame(morans)\n",
        "\n",
        "# sensibilidad (2024): tasa cruda vs EB vs estadístico de tasas de Assunção–Reis\n",
        "d24 = comunal_anual(ULTIMO_COMPLETO)\n",
        "g24 = shp.merge(d24, on=\"IdComuna\", how=\"inner\").reset_index(drop=True)\n",
        "w24s = pesos_para(g24)\n",
        "mi_cruda = esda.Moran(g24[\"p6\"].values, w24s, permutations=999)\n",
        "mi_eb24 = esda.Moran(g24[\"p6_eb\"].values, w24s, permutations=999)\n",
        "mi_rate = esda.moran.Moran_Rate(g24[\"lme_6m\"].values, g24[\"den_6m\"].values,\n",
        "                                w24s, permutations=999)\n",
        "nota(f\"**Sensibilidad {ULTIMO_COMPLETO}**: I cruda = {mi_cruda.I:.3f} \"\n",
        "     f\"(p = {mi_cruda.p_sim:.3f}) | I EB = {mi_eb24.I:.3f} (p = {mi_eb24.p_sim:.3f}) | \"\n",
        "     f\"I de Assunção–Reis = {mi_rate.I:.3f} (p = {mi_rate.p_sim:.3f}) — la \"\n",
        "     \"autocorrelación es robusta al tratamiento de la inestabilidad de tasas.\")\n",
        "boton_tabla(morans.round(3), \"moran_anual\")"
      ],
      "id": "moran-evolucion",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-moran\n",
        "#| code-summary: Evolución del I de Moran\n",
        "#| fig-cap: 'I de Moran global de la LME al 6.º mes comunal (tasas EB), 2009–2024. Pesos Queen estandarizados por filas (islas conectadas por KNN-1); inferencia por 999 permutaciones. Puntos rellenos: p ≤ 0,05.'\n",
        "fig, ax = plt.subplots(figsize=(9, 4.2))\n",
        "sig = morans[\"p_sim\"] <= 0.05\n",
        "ax.axhline(morans[\"EI\"].mean(), color=MUT, lw=1, ls=\":\")\n",
        "ax.annotate(\"E[I] (independencia)\", (morans[\"Ano\"].iloc[0], morans[\"EI\"].mean()),\n",
        "            xytext=(0, 5), textcoords=\"offset points\", color=MUT, fontsize=8)\n",
        "ax.plot(morans[\"Ano\"], morans[\"I\"], color=PAL[0], lw=2)\n",
        "ax.scatter(morans.loc[sig, \"Ano\"], morans.loc[sig, \"I\"],\n",
        "           color=PAL[0], s=42, zorder=3, label=\"p ≤ 0,05\")\n",
        "ax.scatter(morans.loc[~sig, \"Ano\"], morans.loc[~sig, \"I\"],\n",
        "           facecolor=\"white\", edgecolor=PAL[0], s=42, zorder=3, label=\"n.s.\")\n",
        "ax.set_ylabel(\"I de Moran\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Evolución de la autocorrelación espacial de la LME al 6.º mes\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"moran\")"
      ],
      "id": "fig-moran",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "### Autocorrelación espacial por edad de control"
      ],
      "id": "45a80bfc"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-moran-edades\n",
        "#| code-summary: I de Moran anual para el 1.er, 3.er y 6.º mes\n",
        "#| fig-cap: 'Evolución del I de Moran de la LME comunal (tasas EB) según edad de control, 2009–2024. Puntos rellenos: p ≤ 0,05 (999 permutaciones).'\n",
        "morans_edad = []\n",
        "for edad in (\"1m\", \"3m\", \"6m\"):\n",
        "    for anio in range(2009, ULTIMO_COMPLETO + 1):\n",
        "        d = comunal_anual(anio, edad=edad)\n",
        "        if len(d) < 30:\n",
        "            continue\n",
        "        g = shp.merge(d, on=\"IdComuna\", how=\"inner\").reset_index(drop=True)\n",
        "        w = pesos_para(g)\n",
        "        mi = esda.Moran(g[\"p6_eb\"].values, w, permutations=999)\n",
        "        morans_edad.append({\"edad\": edad, \"Ano\": anio, \"I\": mi.I, \"p\": mi.p_sim})\n",
        "morans_edad = pd.DataFrame(morans_edad)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 4.6))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "ax.axhline(0, color=MUT, lw=1, ls=\":\")\n",
        "for i, edad in enumerate((\"1m\", \"3m\", \"6m\")):\n",
        "    s = morans_edad[morans_edad[\"edad\"] == edad]\n",
        "    ax.plot(s[\"Ano\"], s[\"I\"], color=PAL[i], lw=2, label=ETIQ_EDAD[edad])\n",
        "    sig = s[\"p\"] <= 0.05\n",
        "    ax.scatter(s.loc[sig, \"Ano\"], s.loc[sig, \"I\"], color=PAL[i], s=34, zorder=3)\n",
        "    ax.scatter(s.loc[~sig, \"Ano\"], s.loc[~sig, \"I\"], facecolor=\"white\",\n",
        "               edgecolor=PAL[i], s=34, zorder=3)\n",
        "ax.set_ylabel(\"I de Moran\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Autocorrelación espacial de la LME por edad de control\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"moran_edades\")"
      ],
      "id": "fig-moran-edades",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Clústeres locales (LISA) con corrección FDR"
      ],
      "id": "40c42bf3"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: lisa\n",
        "#| code-summary: Moran local con FDR y clasificación de clústeres\n",
        "w25 = pesos_para(gdf_datos)\n",
        "lisa = esda.Moran_Local(gdf_datos[\"p6_eb\"].values, w25,\n",
        "                        permutations=9999, seed=SEED)\n",
        "umbral_fdr = esda.fdr(lisa.p_sim, 0.05)\n",
        "mapa_q = {1: \"HH\", 2: \"LH\", 3: \"LL\", 4: \"HL\"}\n",
        "\n",
        "def clasificar_lisa(pmax):\n",
        "    et = np.array([\"ns\"] * len(gdf_datos), dtype=object)\n",
        "    sig = lisa.p_sim <= pmax\n",
        "    et[sig] = [mapa_q[q] for q in lisa.q[sig]]\n",
        "    return et\n",
        "\n",
        "gdf_datos[\"lisa\"] = clasificar_lisa(0.05)          # criterio convencional\n",
        "gdf_datos[\"lisa_fdr\"] = clasificar_lisa(umbral_fdr)  # criterio conservador\n",
        "\n",
        "nombres_cl = {\"HH\": \"Alto-Alto (hot spot)\", \"LL\": \"Bajo-Bajo (cold spot)\",\n",
        "              \"LH\": \"Bajo-Alto\", \"HL\": \"Alto-Bajo\", \"ns\": \"No significativo\"}\n",
        "conteo = pd.DataFrame({\n",
        "    \"p ≤ 0,05\": pd.Series(gdf_datos[\"lisa\"]).value_counts(),\n",
        "    \"FDR 5 %\": pd.Series(gdf_datos[\"lisa_fdr\"]).value_counts(),\n",
        "}).fillna(0).astype(int).rename(index=nombres_cl)\n",
        "nota(f\"**Umbral FDR** (α = 0,05, {len(gdf_datos)} pruebas simultáneas): \"\n",
        "     f\"p ≤ {umbral_fdr:.5f}.\")\n",
        "boton_tabla(conteo, \"lisa_conteo_clusters\")"
      ],
      "id": "lisa",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-lisa\n",
        "#| code-summary: Mapa de clústeres LISA\n",
        "#| fig-cap: 'Clústeres LISA de la LME al 6.º mes (2024, tasas EB) con el criterio convencional (p ≤ 0,05); las comunas que además sobreviven la corrección FDR al 5 % se destacan con borde negro. Rojo: alta LME rodeada de alta (HH); azul: baja rodeada de baja (LL).'\n",
        "orden_lisa = [\"HH\", \"HL\", \"LH\", \"LL\", \"ns\"]\n",
        "etiquetas_lisa = {\"HH\": \"Alto-Alto\", \"HL\": \"Alto-Bajo\", \"LH\": \"Bajo-Alto\",\n",
        "                  \"LL\": \"Bajo-Bajo\", \"ns\": \"No significativo\"}\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(11.5, 10),\n",
        "                               gridspec_kw={\"width_ratios\": [1, 1.35]})\n",
        "for etq in orden_lisa:\n",
        "    capa = gdf_datos[gdf_datos[\"lisa\"] == etq]\n",
        "    if len(capa):\n",
        "        capa.plot(ax=ax1, color=COL_LISA[etq], edgecolor=\"white\", linewidth=0.15)\n",
        "        capa[capa[\"codregion\"] == 13].plot(ax=ax2, color=COL_LISA[etq],\n",
        "                                           edgecolor=\"white\", linewidth=0.4)\n",
        "capa_fdr = gdf_datos[gdf_datos[\"lisa_fdr\"] != \"ns\"]\n",
        "if len(capa_fdr):\n",
        "    capa_fdr.plot(ax=ax1, facecolor=\"none\", edgecolor=INK, linewidth=0.7)\n",
        "    capa_fdr[capa_fdr[\"codregion\"] == 13].plot(ax=ax2, facecolor=\"none\",\n",
        "                                               edgecolor=INK, linewidth=0.9)\n",
        "import matplotlib.patches as mpatches\n",
        "ax1.legend(handles=[mpatches.Patch(color=COL_LISA[e], label=etiquetas_lisa[e])\n",
        "                    for e in orden_lisa]\n",
        "                   + [mpatches.Patch(facecolor=\"none\", edgecolor=INK,\n",
        "                                     label=\"Sobrevive FDR 5 %\")],\n",
        "           loc=\"center left\", fontsize=8, frameon=False)\n",
        "ax1.set_axis_off(); ax2.set_axis_off()\n",
        "ax1.set_title(f\"Clústeres LISA — Chile, {ULTIMO_COMPLETO}\", fontsize=11)\n",
        "ax2.set_title(\"Región Metropolitana\", fontsize=11)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"lisa\")"
      ],
      "id": "fig-lisa",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Persistencia espacio-temporal de los clústeres"
      ],
      "id": "1bf275fa"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: persistencia\n",
        "#| code-summary: Persistencia de clústeres 2019–2024 y transiciones de terciles\n",
        "#| fig-cap: Persistencia de clústeres LISA (años en que cada comuna fue HH o LL con p ≤ 0,05, 2019–2024). La persistencia multianual reduce la probabilidad de que un falso positivo aislado se clasifique como clúster estable, aunque las pruebas anuales no son independientes entre sí (mismo proceso espacial subyacente), por lo que no constituye un control formal de comparaciones múltiples.\n",
        "anios_persist = list(range(2019, ULTIMO_COMPLETO + 1))\n",
        "registro_lisa = {}\n",
        "for anio in anios_persist:\n",
        "    d = comunal_anual(anio)\n",
        "    g = shp.merge(d, on=\"IdComuna\", how=\"inner\").reset_index(drop=True)\n",
        "    w = pesos_para(g)\n",
        "    li = esda.Moran_Local(g[\"p6_eb\"].values, w, permutations=999, seed=SEED)\n",
        "    et = np.array([\"ns\"] * len(g), dtype=object)\n",
        "    et[li.p_sim <= 0.05] = [mapa_q[q] for q in li.q[li.p_sim <= 0.05]]\n",
        "    registro_lisa[anio] = pd.Series(et, index=g[\"IdComuna\"]).replace(\n",
        "        {\"LH\": \"ns\", \"HL\": \"ns\"})\n",
        "\n",
        "persist = pd.DataFrame(registro_lisa)\n",
        "n_hh = (persist == \"HH\").sum(axis=1)\n",
        "n_ll = (persist == \"LL\").sum(axis=1)\n",
        "persistencia = pd.DataFrame({\"HH_anios\": n_hh, \"LL_anios\": n_ll})\n",
        "persistencia[\"clase\"] = np.select(\n",
        "    [persistencia[\"HH_anios\"] >= 4, persistencia[\"LL_anios\"] >= 4,\n",
        "     persistencia[\"HH_anios\"] >= 1, persistencia[\"LL_anios\"] >= 1],\n",
        "    [\"HH persistente\", \"LL persistente\", \"HH intermitente\", \"LL intermitente\"],\n",
        "    default=\"Nunca significativa\")\n",
        "\n",
        "g_pers = shp.merge(persistencia.reset_index(), on=\"IdComuna\", how=\"left\")\n",
        "col_pers = {\"HH persistente\": PAL[5], \"HH intermitente\": \"#f4a9a8\",\n",
        "            \"LL persistente\": PAL[0], \"LL intermitente\": \"#9ec5f4\",\n",
        "            \"Nunca significativa\": GRID}\n",
        "fig, ax = plt.subplots(figsize=(6, 10))\n",
        "for clase, color in col_pers.items():\n",
        "    capa = g_pers[g_pers[\"clase\"] == clase]\n",
        "    if len(capa):\n",
        "        capa.plot(ax=ax, color=color, edgecolor=\"white\", linewidth=0.15)\n",
        "g_pers[g_pers[\"clase\"].isna()].plot(ax=ax, color=\"white\",\n",
        "                                    edgecolor=GRID, linewidth=0.15)\n",
        "ax.legend(handles=[mpatches.Patch(color=c, label=l) for l, c in col_pers.items()],\n",
        "          loc=\"center left\", fontsize=8, frameon=False)\n",
        "ax.set_axis_off()\n",
        "ax.set_title(\"Persistencia de clústeres LISA de LME₆, 2019–2024\", fontsize=11)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"persistencia\")\n",
        "\n",
        "tabla_pers = (persistencia[\"clase\"].value_counts().to_frame(\"Comunas\"))\n",
        "boton_tabla(tabla_pers, \"lisa_persistencia\")"
      ],
      "id": "persistencia",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: markov\n",
        "#| code-summary: Matriz de transición de terciles (2009–2013 → 2021–2024)\n",
        "#| tbl-cap: 'Movilidad territorial: transición entre terciles de LME al 6.º mes desde el quinquenio 2009–2013 al cuadrienio 2021–2024 (probabilidades por fila).'\n",
        "def promedio_periodo(anios):\n",
        "    d = (cm[cm[\"Ano\"].isin(anios)]\n",
        "         .groupby(\"IdComuna\")[[\"lme_6m\", \"den_6m\"]].sum())\n",
        "    d = d[d[\"den_6m\"] >= 150]\n",
        "    return 100 * d[\"lme_6m\"] / d[\"den_6m\"]\n",
        "\n",
        "p_ini = promedio_periodo(range(2009, 2014))\n",
        "p_fin = promedio_periodo(range(2021, ULTIMO_COMPLETO + 1))\n",
        "ambos = pd.DataFrame({\"ini\": p_ini, \"fin\": p_fin}).dropna()\n",
        "ambos[\"terc_ini\"] = pd.qcut(ambos[\"ini\"], 3, labels=[\"T1 (baja)\", \"T2\", \"T3 (alta)\"])\n",
        "ambos[\"terc_fin\"] = pd.qcut(ambos[\"fin\"], 3, labels=[\"T1 (baja)\", \"T2\", \"T3 (alta)\"])\n",
        "trans = pd.crosstab(ambos[\"terc_ini\"], ambos[\"terc_fin\"], normalize=\"index\").round(2)\n",
        "\n",
        "from scipy.stats import chi2_contingency\n",
        "chi2, p_chi, *_ = chi2_contingency(pd.crosstab(ambos[\"terc_ini\"], ambos[\"terc_fin\"]))\n",
        "nota(f\"n = {len(ambos)} comunas | χ² = {chi2:.1f}, p = {p_chi:.1e} — \"\n",
        "     \"fuerte persistencia del rango territorial.\")\n",
        "boton_tabla(trans, \"transicion_terciles\")"
      ],
      "id": "markov",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Desigualdad territorial"
      ],
      "id": "bc5266c6"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-desigualdad\n",
        "#| code-summary: Gini y Theil ponderados; descomposición del Theil\n",
        "#| fig-cap: 'Desigualdad territorial de la LME al 6.º mes, 2009–2024. Izquierda: Gini ponderado y razón p90/p10 entre comunas. Derecha: índice de Theil descompuesto en componentes entre-regiones y dentro-de-regiones.'\n",
        "def gini_ponderado(x, w):\n",
        "    idx = np.argsort(x)\n",
        "    x, w = np.asarray(x)[idx], np.asarray(w)[idx]\n",
        "    cw = np.cumsum(w) - 0.5 * w\n",
        "    cw /= w.sum()\n",
        "    mu = np.average(x, weights=w)\n",
        "    return 2 * np.sum(w * (x - mu) * (cw - 0.5)) / (w.sum() * mu)\n",
        "\n",
        "def percentil_ponderado(x, w, q):\n",
        "    idx = np.argsort(x)\n",
        "    x, w = np.asarray(x)[idx], np.asarray(w)[idx]\n",
        "    c = np.cumsum(w) / np.sum(w)\n",
        "    return np.interp(q, c, x)\n",
        "\n",
        "def theil_descompuesto(df):\n",
        "    mu = np.average(df[\"p6\"], weights=df[\"den_6m\"])\n",
        "    w = df[\"den_6m\"] / df[\"den_6m\"].sum()\n",
        "    r = df[\"p6\"] / mu\n",
        "    T_total = np.sum(w * r * np.log(np.where(r > 0, r, 1)))\n",
        "    entre, dentro = 0.0, 0.0\n",
        "    for _, g in df.groupby(\"region\"):\n",
        "        wg = g[\"den_6m\"].sum() / df[\"den_6m\"].sum()\n",
        "        mug = np.average(g[\"p6\"], weights=g[\"den_6m\"])\n",
        "        entre += wg * (mug / mu) * np.log(mug / mu)\n",
        "        wgi = g[\"den_6m\"] / g[\"den_6m\"].sum()\n",
        "        rgi = g[\"p6\"] / mug\n",
        "        dentro += wg * (mug / mu) * np.sum(wgi * rgi * np.log(np.where(rgi > 0, rgi, 1)))\n",
        "    return T_total, entre, dentro\n",
        "\n",
        "com_reg = (cm[cm[\"Ano\"] <= ULTIMO_COMPLETO]\n",
        "           .groupby([\"Ano\", \"IdComuna\", \"region\"])[[\"lme_6m\", \"den_6m\"]]\n",
        "           .sum().reset_index())\n",
        "com_reg = com_reg[com_reg[\"den_6m\"] >= 30]\n",
        "com_reg[\"p6\"] = 100 * com_reg[\"lme_6m\"] / com_reg[\"den_6m\"]\n",
        "\n",
        "filas = []\n",
        "for anio, d in com_reg.groupby(\"Ano\"):\n",
        "    T, entre, dentro = theil_descompuesto(d)\n",
        "    filas.append({\n",
        "        \"Ano\": anio,\n",
        "        \"gini\": gini_ponderado(d[\"p6\"], d[\"den_6m\"]),\n",
        "        \"p90_p10\": (percentil_ponderado(d[\"p6\"], d[\"den_6m\"], 0.9)\n",
        "                    / percentil_ponderado(d[\"p6\"], d[\"den_6m\"], 0.1)),\n",
        "        \"theil\": T, \"theil_entre\": entre, \"theil_dentro\": dentro,\n",
        "    })\n",
        "desig = pd.DataFrame(filas).set_index(\"Ano\")\n",
        "desig.round(4).to_csv(OUT / \"desigualdad_territorial.csv\")\n",
        "\n",
        "fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(11, 4.4))\n",
        "ax1.plot(desig.index, desig[\"gini\"], color=PAL[0], lw=2, marker=\"o\", ms=4,\n",
        "         label=\"Gini ponderado\")\n",
        "ax1b_vals = desig[\"p90_p10\"]\n",
        "ax1.plot(desig.index, (ax1b_vals - ax1b_vals.min()) /\n",
        "         (ax1b_vals.max() - ax1b_vals.min()) * desig[\"gini\"].max(),\n",
        "         color=PAL[2], lw=1.6, marker=\"s\", ms=3.5,\n",
        "         label=\"p90/p10 (reescalada)\")\n",
        "ax1.set_title(\"Desigualdad entre comunas\")\n",
        "ax1.set_ylabel(\"Índice\")\n",
        "ax1.legend(frameon=False)\n",
        "\n",
        "ax2.stackplot(desig.index, desig[\"theil_entre\"], desig[\"theil_dentro\"],\n",
        "              colors=[PAL[0], \"#9ec5f4\"],\n",
        "              labels=[\"Entre regiones\", \"Dentro de regiones\"])\n",
        "ax2.set_title(\"Índice de Theil (descomposición)\")\n",
        "ax2.set_ylabel(\"Theil\")\n",
        "ax2.legend(frameon=False, loc=\"upper right\")\n",
        "for ax in (ax1, ax2):\n",
        "    ax.set_xlabel(\"Año\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"desigualdad\")\n",
        "pct_entre = 100 * desig[\"theil_entre\"] / desig[\"theil\"]\n",
        "nota(f\"**Componente entre-regiones del Theil**: {pct_entre.iloc[0]:.0f} % (2009) → \"\n",
        "     f\"{pct_entre.iloc[-1]:.0f} % ({ULTIMO_COMPLETO}) — la mayor parte de la \"\n",
        "     \"desigualdad territorial ocurre dentro de las regiones.\")"
      ],
      "id": "fig-desigualdad",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Modelos\n",
        "\n",
        "## Panel nacional 2009–2024: trayectoria ajustada"
      ],
      "id": "963c7c06"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: glm-panel\n",
        "#| code-summary: GLM binomial con efectos fijos de año y región, EE agrupados por comuna\n",
        "#| fig-cap: Razones de odds de LME al 6.º mes por año (referencia 2010, primer año con cobertura comunal completa), ajustadas por región, con IC 95 % robustos a la agrupación por comuna.\n",
        "import patsy\n",
        "\n",
        "pnl = com_reg.copy()\n",
        "pnl[\"fracasos\"] = pnl[\"den_6m\"] - pnl[\"lme_6m\"]\n",
        "\n",
        "# referencia = 2010, primer año con cobertura comunal completa (2009 informa ~302)\n",
        "X_glm = patsy.dmatrix(\"C(Ano, Treatment(reference=2010)) + C(region)\",\n",
        "                      pnl, return_type=\"dataframe\")\n",
        "mod_glm = sm.GLM(pnl[[\"lme_6m\", \"fracasos\"]], X_glm,\n",
        "                 family=sm.families.Binomial()).fit(\n",
        "    cov_type=\"cluster\", cov_kwds={\"groups\": pnl[\"IdComuna\"]})\n",
        "\n",
        "coefs = mod_glm.params.filter(like=\"C(Ano\")\n",
        "ci = mod_glm.conf_int().filter(like=\"C(Ano\", axis=0)\n",
        "anios_or = [int(s.split(\"[T.\")[1].rstrip(\"]\")) for s in coefs.index]\n",
        "or_df = pd.DataFrame({\n",
        "    \"Ano\": anios_or, \"OR\": np.exp(coefs.values),\n",
        "    \"lo\": np.exp(ci[0].values), \"hi\": np.exp(ci[1].values)}).set_index(\"Ano\")\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9, 4.4))\n",
        "ax.axhline(1, color=MUT, lw=1, ls=\":\")\n",
        "ax.errorbar(or_df.index, or_df[\"OR\"],\n",
        "            yerr=[or_df[\"OR\"] - or_df[\"lo\"], or_df[\"hi\"] - or_df[\"OR\"]],\n",
        "            fmt=\"o\", color=PAL[0], ms=5, lw=1.4, capsize=2)\n",
        "ax.set_ylabel(\"OR de LME₆ (ref. 2010)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Trayectoria nacional ajustada de la LME al 6.º mes (GLM binomial)\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"glm_panel\")"
      ],
      "id": "glm-panel",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Regresión espacial (corte transversal 2024)"
      ],
      "id": "660c9423"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: spreg\n",
        "#| code-summary: MCO con diagnósticos LM, ML-Lag y ML-Error\n",
        "# covariables internas del REM: tamaño (log controles) y composición de los controles\n",
        "comp = cm[cm[\"Ano\"] == ULTIMO_COMPLETO].groupby(\"IdComuna\").agg(\n",
        "    den_6m=(\"den_6m\", \"sum\"), lme_6m=(\"lme_6m\", \"sum\"),\n",
        "    den_total=(\"den_total\", \"sum\"), den_po=(\"den_po\", \"sum\"),\n",
        "    den_mig=(\"den_mig\", \"sum\")).reset_index()\n",
        "comp = comp[comp[\"den_6m\"] >= 30]\n",
        "comp[\"p6_eb\"] = 100 * eb_suavizar(comp[\"lme_6m\"], comp[\"den_6m\"])\n",
        "comp[\"log_den\"] = np.log(comp[\"den_6m\"])\n",
        "comp[\"pct_po\"] = 100 * comp[\"den_po\"] / comp[\"den_total\"].replace(0, np.nan)\n",
        "comp[\"pct_mig\"] = 100 * comp[\"den_mig\"] / comp[\"den_total\"].replace(0, np.nan)\n",
        "comp = comp.dropna(subset=[\"pct_po\", \"pct_mig\"])\n",
        "\n",
        "g_mod = shp.merge(comp, on=\"IdComuna\", how=\"inner\").reset_index(drop=True)\n",
        "w_mod = pesos_para(g_mod)\n",
        "\n",
        "y = g_mod[[\"p6_eb\"]].values\n",
        "X = g_mod[[\"log_den\", \"pct_po\", \"pct_mig\"]].values\n",
        "nombres_x = [\"log(controles 6m)\", \"% pueblos originarios\", \"% migrantes\"]\n",
        "\n",
        "ols = spreg.OLS(y, X, w=w_mod, spat_diag=True, moran=True,\n",
        "                name_y=\"LME6_EB\", name_x=nombres_x)\n",
        "lag = spreg.ML_Lag(y, X, w=w_mod, name_y=\"LME6_EB\", name_x=nombres_x)\n",
        "err = spreg.ML_Error(y, X, w=w_mod, name_y=\"LME6_EB\", name_x=nombres_x)\n",
        "\n",
        "def fila(nombre, m, extra=\"\"):\n",
        "    return {\"Modelo\": nombre, \"AIC\": round(getattr(m, \"aic\", np.nan), 1),\n",
        "            \"Pseudo/R²\": round(getattr(m, \"pr2\", getattr(m, \"r2\", np.nan)), 3),\n",
        "            \"Parámetro espacial\": extra}\n",
        "\n",
        "comp_tab = pd.DataFrame([\n",
        "    fila(\"MCO\", ols),\n",
        "    fila(\"Rezago espacial (ML-Lag)\", lag, f\"ρ = {float(lag.rho):.3f}\"),\n",
        "    fila(\"Error espacial (ML-Error)\", err, f\"λ = {float(err.lam):.3f}\"),\n",
        "])\n",
        "nota(f\"**Diagnósticos LM (MCO)**: LM-lag p = {ols.lm_lag[1]:.4f} | \"\n",
        "     f\"LM-error p = {ols.lm_error[1]:.4f} | LM-lag robusto p = {ols.rlm_lag[1]:.4f} | \"\n",
        "     f\"LM-error robusto p = {ols.rlm_error[1]:.4f}. Regla de Anselin–Florax: con ambos \"\n",
        "     \"LM robustos no significativos, los diagnósticos no discriminan entre rezago y \"\n",
        "     \"error espacial; se reportan ambas especificaciones sin declarar una «mejor».\")\n",
        "\n",
        "# sensibilidad: misma especificación sobre la tasa CRUDA (la tasa EB depende de\n",
        "# den_6m por construcción, lo que vuelve mecánica parte de la asociación con log_den)\n",
        "y_cruda = (100 * g_mod[\"lme_6m\"] / g_mod[\"den_6m\"]).values.reshape(-1, 1)\n",
        "err_crudo = spreg.ML_Error(y_cruda, X, w=w_mod, name_y=\"LME6_cruda\", name_x=nombres_x)\n",
        "nota(f\"**Sensibilidad con tasa cruda** (ML-Error): λ = {float(err_crudo.lam):.3f}; \"\n",
        "     f\"coeficiente de log(controles): EB = {err.betas[1, 0]:.3f} vs cruda = \"\n",
        "     f\"{err_crudo.betas[1, 0]:.3f}. El coeficiente de tamaño **no** es interpretable \"\n",
        "     \"como efecto causal: parte es artefacto de la contracción EB.\")\n",
        "boton_tabla(comp_tab, \"modelos_espaciales_comparacion\")"
      ],
      "id": "spreg",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: spreg-coef\n",
        "#| code-summary: Coeficientes de ambas especificaciones espaciales\n",
        "#| tbl-cap: Coeficientes de los modelos de rezago espacial (ML-Lag) y de error espacial (ML-Error) para la LME al 6.º mes comunal (2024, tasas EB). Los diagnósticos LM robustos no discriminan entre especificaciones; el AIC favorece levemente al ML-Error.\n",
        "def tabla_coefs(m, param_esp, nombre_esp):\n",
        "    ee = np.sqrt(np.diag(m.vm))\n",
        "    variables = [\"Constante\"] + nombres_x + [nombre_esp]\n",
        "    coefs = list(m.betas.flatten()[:len(nombres_x) + 1]) + [float(param_esp)]\n",
        "    ees = list(ee[:len(nombres_x) + 1]) + [float(ee[-1])]\n",
        "    return pd.DataFrame({\"Coef.\": coefs, \"EE\": ees}, index=variables)\n",
        "\n",
        "t_lag = tabla_coefs(lag, lag.rho, \"ρ (rezago)\").add_suffix(\" ML-Lag\")\n",
        "t_err = tabla_coefs(err, err.lam, \"λ (error)\").rename(\n",
        "    index={\"λ (error)\": \"ρ (rezago)\"}).add_suffix(\" ML-Error\")\n",
        "coef_ambos = t_lag.join(t_err, how=\"outer\").rename(\n",
        "    index={\"ρ (rezago)\": \"Parámetro espacial (ρ / λ)\"})\n",
        "boton_tabla(coef_ambos.round(3), \"coeficientes_espaciales\")"
      ],
      "id": "spreg-coef",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Composición de la alimentación y poblaciones específicas\n",
        "\n",
        "## Composición de tipos de alimentación al 6.º mes (2017–2026)\n",
        "\n",
        "Desde 2017 el REM desagrega la alimentación del niño controlado más allá de la LME:\n",
        "lactancia con fórmula (mixta, 03500359), fórmula exclusiva (03500360) y, desde 2021,\n",
        "las variantes con alimentación complementaria (03600140, 03600150). Esto permite\n",
        "reconstruir la **composición completa** de la alimentación al 6.º mes."
      ],
      "id": "37e5a9d7"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-composicion\n",
        "#| code-summary: Composición 100 % de la alimentación al 6.º mes\n",
        "#| fig-cap: Composición de la alimentación infantil en el control del 6.º mes, 2017–2026 (porcentaje de los niños controlados). «Sin clasificar» es el residuo (truncado en 0) entre el denominador y la suma de categorías; desde 2024 la suma de categorías excede levemente el denominador (~1 pp) por inconsistencias de registro. La línea vertical marca 2021, cuando el formulario agregó las categorías con alimentación complementaria. Años 2025–2026 provisionales.\n",
        "CODIGOS_TIPO = [\n",
        "    (\"A0200002\", \"LME\", PAL[0]),\n",
        "    (\"A0200003\", \"LM + alimentación complementaria\", PAL[1]),\n",
        "    (\"03500359\", \"LM + fórmula (mixta)\", PAL[2]),\n",
        "    (\"03600140\", \"LM + fórmula + complementaria\", PAL[4]),\n",
        "    (\"03500360\", \"Fórmula exclusiva\", PAL[5]),\n",
        "    (\"03600150\", \"Fórmula + complementaria\", PAL[7]),\n",
        "]\n",
        "den6_anual = cm.groupby(\"Ano\")[\"den_6m\"].sum()\n",
        "partes_comp = {}\n",
        "for cod, etiqueta, _ in CODIGOS_TIPO:\n",
        "    t = arm[arm[\"codigo\"] == cod].groupby(\"Ano\")[\"6m\"].sum()\n",
        "    partes_comp[etiqueta] = (100 * t / den6_anual).reindex(den6_anual.index).fillna(0)\n",
        "comp_df = pd.DataFrame(partes_comp).loc[2017:]\n",
        "comp_df[\"Sin clasificar\"] = (100 - comp_df.sum(axis=1)).clip(lower=0)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 5.4))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "colores_comp = [c for _, _, c in CODIGOS_TIPO] + [GRID]\n",
        "ax.stackplot(comp_df.index, comp_df.T.values, labels=comp_df.columns,\n",
        "             colors=colores_comp, alpha=0.9)\n",
        "ax.axvline(2021, color=INK2, lw=1, ls=\":\")\n",
        "ax.annotate(\"nuevas categorías\", (2021, 99), color=INK2, fontsize=8,\n",
        "            ha=\"center\", va=\"top\")\n",
        "ax.set_xlim(2017, 2026)\n",
        "ax.set_ylim(0, 100)\n",
        "ax.set_ylabel(\"% de niños controlados al 6.º mes\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Composición de la alimentación al 6.º mes, 2017–2026\")\n",
        "ax.legend(loc=\"center left\", bbox_to_anchor=(1.01, 0.5), frameon=False, fontsize=8.5)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"composicion\")\n",
        "comp_df.round(2).to_csv(OUT / \"composicion_alimentacion_6m.csv\")\n",
        "exceso_anios = comp_df.index[comp_df.drop(columns=\"Sin clasificar\").sum(axis=1) > 100.5]\n",
        "nota(\"Antes de 2021 los niños con lactancia mixta o fórmula **más alimentación \"\n",
        "     \"complementaria** (códigos 03600140 y 03600150) no tenían categoría propia, por \"\n",
        "     \"lo que el bloque «sin clasificar» es mayor en 2017–2020: la comparación fina de \"\n",
        "     \"categorías mixtas solo es válida desde 2021.\"\n",
        "     + (f\" En {', '.join(map(str, exceso_anios))} la suma de categorías supera el \"\n",
        "        \"denominador (inconsistencia de registro; el residuo se trunca en 0).\"\n",
        "        if len(exceso_anios) else \"\"))"
      ],
      "id": "fig-composicion",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Brecha por sexo (2017–2022)"
      ],
      "id": "ed5e9f5c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-sexo\n",
        "#| code-summary: LME al 6.º mes por sexo\n",
        "#| fig-cap: 'LME al 6.º mes por sexo del lactante, 2017–2022 (única era del REM con desagregación por sexo). Bandas: IC 95 % de Wilson.'\n",
        "sx = arm[(arm[\"codigo\"].isin([COD_LME, COD_DEN])) &\n",
        "         (arm[\"Ano\"].between(2017, 2022))]\n",
        "res_sx = []\n",
        "for sexo, color in [(\"H\", PAL[0]), (\"M\", PAL[6])]:\n",
        "    col = f\"6m_{sexo}\"\n",
        "    if col not in sx.columns:\n",
        "        continue\n",
        "    t = sx.groupby([\"Ano\", \"codigo\"])[col].sum().unstack(\"codigo\")\n",
        "    p = 100 * t[COD_LME] / t[COD_DEN]\n",
        "    lo, hi = proportion_confint(t[COD_LME], t[COD_DEN], method=\"wilson\")\n",
        "    res_sx.append((sexo, p, 100 * lo, 100 * hi, color))\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8.5, 4.4))\n",
        "etiq_sx = {\"H\": \"Niños\", \"M\": \"Niñas\"}\n",
        "for sexo, p, lo, hi, color in res_sx:\n",
        "    ax.plot(p.index, p.values, color=color, lw=2, marker=\"o\", ms=4,\n",
        "            label=etiq_sx[sexo])\n",
        "    ax.fill_between(p.index, lo, hi, color=color, alpha=0.15, lw=0)\n",
        "ax.set_ylabel(\"LME₆ (%)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Brecha por sexo en la LME al 6.º mes, 2017–2022\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"sexo\")\n",
        "if len(res_sx) == 2:\n",
        "    dif = res_sx[1][1] - res_sx[0][1]\n",
        "    nota(\"**Diferencia niñas − niños** (pp): \"\n",
        "         + \"; \".join(f\"{a}: {v:+.1f}\" for a, v in dif.round(1).items()) + \".\")"
      ],
      "id": "fig-sexo",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-sexo-edades\n",
        "#| code-summary: Brecha por sexo según edad de control\n",
        "#| fig-cap: Brecha por sexo (niñas − niños, puntos porcentuales) en la LME según edad de control, 2017–2022.\n",
        "brechas_sx = {}\n",
        "for edad in (\"1m\", \"3m\", \"6m\"):\n",
        "    ch, cm_ = f\"{edad}_H\", f\"{edad}_M\"\n",
        "    t = sx.groupby([\"Ano\", \"codigo\"])[[ch, cm_]].sum()\n",
        "    lme_t = t.xs(COD_LME, level=\"codigo\")\n",
        "    den_t = t.xs(COD_DEN, level=\"codigo\")\n",
        "    p_h = 100 * lme_t[ch] / den_t[ch]\n",
        "    p_m = 100 * lme_t[cm_] / den_t[cm_]\n",
        "    brechas_sx[edad] = p_m - p_h\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8.5, 4.2))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "ax.axhline(0, color=MUT, lw=1, ls=\":\")\n",
        "for i, (edad, b) in enumerate(brechas_sx.items()):\n",
        "    ax.plot(b.index, b.values, color=PAL[i], lw=2, marker=\"o\", ms=4,\n",
        "            label=ETIQ_EDAD[edad])\n",
        "ax.set_ylabel(\"Brecha niñas − niños (pp)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"Brecha por sexo en la LME según edad de control, 2017–2022\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"sexo_edades\")"
      ],
      "id": "fig-sexo-edades",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Pueblos originarios y migrantes (2021+)\n",
        "\n",
        "Las columnas de pueblos originarios y migrantes tienen **calidad de registro\n",
        "sustancialmente menor** que el resto de la sección: el denominador grupal de A0200001\n",
        "está subregistrado respecto del numerador (los controles migrantes acumulados\n",
        "2021–2024 equivalen a ~1 % del denominador total, implausible frente a la proporción\n",
        "migrante de los nacimientos) y abundan celdas comuna-mes con numerador mayor que su\n",
        "denominador. Por eso estos análisis usan un tratamiento específico: las celdas\n",
        "inconsistentes se **excluyen de ambos lados** (numerador y denominador) en lugar de\n",
        "truncarse, el mismo criterio en las dos figuras, y se reporta la sensibilidad. Las\n",
        "brechas resultantes deben leerse como indicadores de **calidad de registro tanto como\n",
        "de práctica de lactancia**."
      ],
      "id": "1b9290e0"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: equidad-datos\n",
        "#| code-summary: Preparación consistente de los datos de PO/migrantes\n",
        "eqc = {}\n",
        "for grupo in (\"po\", \"mig\", \"total\"):\n",
        "    lme_g = (arm[arm[\"codigo\"] == COD_LME]\n",
        "             .groupby([\"Ano\", \"Mes\", \"IdComuna\", \"region\"])[grupo].sum())\n",
        "    den_g = (arm[arm[\"codigo\"] == COD_DEN]\n",
        "             .groupby([\"Ano\", \"Mes\", \"IdComuna\", \"region\"])[grupo].sum())\n",
        "    t = pd.DataFrame({\"lme\": lme_g, \"den\": den_g}).fillna(0)\n",
        "    inconsistentes = t[\"lme\"] > t[\"den\"]\n",
        "    t.loc[inconsistentes, [\"lme\", \"den\"]] = 0.0  # exclusión de ambos lados\n",
        "    t[\"excluida\"] = inconsistentes\n",
        "    eqc[grupo] = t.reset_index()\n",
        "excl_txt = {g: f\"{int(t['excluida'].sum()):,}\" for g, t in eqc.items()}\n",
        "nota(\"Celdas comuna-mes excluidas por registro inconsistente (numerador > \"\n",
        "     f\"denominador): pueblos originarios {excl_txt['po']}, migrantes \"\n",
        "     f\"{excl_txt['mig']}, total {excl_txt['total']}. **Sensibilidad**: con \"\n",
        "     \"truncamiento (num := den) en vez de exclusión, la brecha migrante cambia de \"\n",
        "     \"signo en varias regiones; los resultados de esta sección son, por tanto, \"\n",
        "     \"fuertemente dependientes de la calidad del registro grupal.\")"
      ],
      "id": "equidad-datos",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-equidad\n",
        "#| code-summary: Brechas de LME en poblaciones específicas\n",
        "#| fig-cap: LME en pueblos originarios y migrantes respecto del total nacional, 2021–2026 (celdas inconsistentes excluidas de numerador y denominador). En estas columnas del REM la LME no se desagrega por edad de control, por lo que se compara contra el total de la sección.\n",
        "filas_eq = []\n",
        "for grupo, etiqueta in [(\"po\", \"Pueblos originarios\"), (\"mig\", \"Migrantes\"),\n",
        "                        (\"total\", \"Total\")]:\n",
        "    t = (eqc[grupo][eqc[grupo][\"Ano\"] >= 2021]\n",
        "         .groupby(\"Ano\")[[\"lme\", \"den\"]].sum())\n",
        "    t = t[t[\"den\"] > 0]\n",
        "    filas_eq.append(pd.DataFrame({\n",
        "        \"Ano\": t.index, \"grupo\": etiqueta, \"p\": 100 * t[\"lme\"] / t[\"den\"]}))\n",
        "eq_df = pd.concat(filas_eq)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(8.5, 4.4))\n",
        "colores_eq = {\"Total\": MUT, \"Pueblos originarios\": PAL[2], \"Migrantes\": PAL[4]}\n",
        "for etiqueta, d in eq_df.groupby(\"grupo\"):\n",
        "    ax.plot(d[\"Ano\"], d[\"p\"], lw=2, marker=\"o\", ms=4,\n",
        "            color=colores_eq[etiqueta], label=etiqueta)\n",
        "ax.axvspan(2024.5, 2026.5, color=GRID, alpha=0.35, zorder=0)\n",
        "ax.set_ylabel(\"LME (%) — total de la sección\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"LME en poblaciones específicas, 2021–2026\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"equidad\")"
      ],
      "id": "fig-equidad",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-equidad-regional\n",
        "#| code-summary: Brechas regionales en pueblos originarios y migrantes\n",
        "#| fig-cap: LME (total de la sección) por región en pueblos originarios y migrantes respecto de la población total, 2021–2024 agrupados, con celdas inconsistentes excluidas de ambos lados. Cada segmento une la prevalencia del grupo con la del total regional; regiones ordenadas de norte a sur. El punto de un grupo se omite cuando la región acumula menos de 200 controles de ese grupo en el período (denominadores inestables); dado el subregistro de los denominadores grupales, estas brechas reflejan calidad de registro tanto como práctica de lactancia.\n",
        "eqr_parts = {\n",
        "    g: (eqc[g][eqc[g][\"Ano\"].between(2021, ULTIMO_COMPLETO)]\n",
        "        .groupby(\"region\")[[\"lme\", \"den\"]].sum())\n",
        "    for g in (\"po\", \"mig\", \"total\")\n",
        "}\n",
        "UMBRAL_GRUPO = 200  # mínimo de controles acumulados por grupo y región\n",
        "eqr = pd.DataFrame({\n",
        "    \"p_total\": 100 * eqr_parts[\"total\"][\"lme\"] / eqr_parts[\"total\"][\"den\"],\n",
        "    \"p_po\": (100 * eqr_parts[\"po\"][\"lme\"] / eqr_parts[\"po\"][\"den\"])\n",
        "        .where(eqr_parts[\"po\"][\"den\"] >= UMBRAL_GRUPO),\n",
        "    \"p_mig\": (100 * eqr_parts[\"mig\"][\"lme\"] / eqr_parts[\"mig\"][\"den\"])\n",
        "        .where(eqr_parts[\"mig\"][\"den\"] >= UMBRAL_GRUPO),\n",
        "})\n",
        "eqr = eqr[eqr[[\"p_po\", \"p_mig\"]].notna().any(axis=1)]\n",
        "orden_pres = [r for r in orden_reg if r in eqr.index]\n",
        "eqr = eqr.loc[orden_pres]\n",
        "omitidas = [f\"{NOMBRES_REGION[r]} ({g})\"\n",
        "            for g, col in ((\"PO\", \"p_po\"), (\"mig\", \"p_mig\"))\n",
        "            for r in eqr.index[eqr[col].isna()]]\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(9.5, 7))\n",
        "ypos = np.arange(len(eqr))[::-1]\n",
        "for y, (_, fila) in zip(ypos, eqr.iterrows()):\n",
        "    if np.isfinite(fila[\"p_po\"]):\n",
        "        ax.plot([fila[\"p_total\"], fila[\"p_po\"]], [y + 0.16, y + 0.16],\n",
        "                color=PAL[2], lw=1.4, zorder=1)\n",
        "    if np.isfinite(fila[\"p_mig\"]):\n",
        "        ax.plot([fila[\"p_total\"], fila[\"p_mig\"]], [y - 0.16, y - 0.16],\n",
        "                color=PAL[4], lw=1.4, zorder=1)\n",
        "ax.scatter(eqr[\"p_total\"], ypos + 0.16, color=MUT, s=34, zorder=2)\n",
        "ax.scatter(eqr[\"p_total\"], ypos - 0.16, color=MUT, s=34, zorder=2, label=\"Total regional\")\n",
        "ax.scatter(eqr[\"p_po\"], ypos + 0.16, color=PAL[2], s=44, zorder=3,\n",
        "           label=\"Pueblos originarios\")\n",
        "ax.scatter(eqr[\"p_mig\"], ypos - 0.16, color=PAL[4], s=44, zorder=3, label=\"Migrantes\")\n",
        "ax.set_yticks(ypos)\n",
        "ax.set_yticklabels([NOMBRES_REGION[r] for r in eqr.index], fontsize=9)\n",
        "ax.set_xlabel(\"LME (%) — total de la sección, 2021–2024\")\n",
        "ax.set_title(\"Brechas regionales de LME en poblaciones específicas\")\n",
        "ax.legend(frameon=False, loc=\"lower right\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"equidad_regional\")\n",
        "if omitidas:\n",
        "    nota(\"Grupos omitidos por denominador regional < 200 controles acumulados: \"\n",
        "         + \"; \".join(omitidas) + \".\")\n",
        "(eqr[[\"p_total\", \"p_po\", \"p_mig\"]].round(2)\n",
        " .rename(index=NOMBRES_REGION).to_csv(OUT / \"brechas_regionales_po_mig.csv\"))"
      ],
      "id": "fig-equidad-regional",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Díadas neonatales (2023+)\n",
        "\n",
        "Desde 2023 el REM registra la lactancia en la **díada madre–recién nacido** en los\n",
        "primeros controles de vida: en 2023 con una única columna neonatal y desde 2024\n",
        "desagregada en dos ventanas (hasta 10 días y entre 11 y 28 días). Esto permite\n",
        "observar el punto de partida de la LME antes del primer mes; el punto 2023 se muestra\n",
        "aislado porque no es comparable con las ventanas desagregadas."
      ],
      "id": "ca5d8541"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: fig-diadas\n",
        "#| code-summary: LME en las díadas neonatales\n",
        "#| fig-cap: LME en los controles de díada comparada con el 1.er y el 6.º mes. En 2023 el REM registró una única columna neonatal (rombo aislado); las ventanas ≤10 días y 11–28 días existen desde 2024 y no son comparables con 2023. Años 2025–2026 provisionales.\n",
        "cols_diada = [c for c in (\"diada_0_10\", \"diada_11_28\") if f\"den_{c}\" in cm.columns]\n",
        "dd = cm[cm[\"Ano\"] >= 2023].groupby(\"Ano\")[\n",
        "    [f\"lme_{c}\" for c in cols_diada] + [f\"den_{c}\" for c in cols_diada]\n",
        "    + [\"lme_1m\", \"den_1m\", \"lme_6m\", \"den_6m\"]].sum()\n",
        "\n",
        "series_dd = {\"Díada ≤10 días\": (\"diada_0_10\", PAL[6]),\n",
        "             \"Díada 11–28 días\": (\"diada_11_28\", PAL[4]),\n",
        "             \"1.er mes\": (\"1m\", PAL[0]), \"6.º mes\": (\"6m\", PAL[2])}\n",
        "fig, ax = plt.subplots(figsize=(8.5, 4.6))\n",
        "ax.xaxis.set_major_locator(mpl.ticker.MaxNLocator(integer=True))\n",
        "for etiqueta, (clave, color) in series_dd.items():\n",
        "    if f\"den_{clave}\" not in dd.columns:\n",
        "        continue\n",
        "    den_s = dd[f\"den_{clave}\"].replace(0, np.nan)\n",
        "    p = (100 * dd[f\"lme_{clave}\"] / den_s).dropna()\n",
        "    if clave == \"diada_11_28\" and 2023 in p.index:\n",
        "        # 2023: columna única sin desagregación etaria -> punto aislado\n",
        "        ax.scatter([2023], [p.loc[2023]], color=color, marker=\"D\", s=48, zorder=3,\n",
        "                   label=\"Díada ≤28 días (columna única 2023)\")\n",
        "        p = p.drop(index=2023)\n",
        "    if p.empty:\n",
        "        continue\n",
        "    ax.plot(p.index, p.values, color=color, lw=2, marker=\"o\", ms=5, label=etiqueta)\n",
        "ax.axvspan(2024.5, 2026.5, color=GRID, alpha=0.35, zorder=0)\n",
        "ax.set_ylabel(\"LME (%)\")\n",
        "ax.set_xlabel(\"Año\")\n",
        "ax.set_title(\"LME desde la díada neonatal hasta el 6.º mes, 2023–2026\")\n",
        "ax.legend(frameon=False)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "boton_figura(fig, \"diadas\")"
      ],
      "id": "fig-diadas",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# Mapa interactivo"
      ],
      "id": "769f314c"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| label: folium\n",
        "#| code-summary: 'Mapa interactivo (folium): tasas EB y clústeres LISA 2024'\n",
        "import folium\n",
        "import branca.colormap as bcm\n",
        "\n",
        "g4326 = gdf_datos.to_crs(4326).copy()\n",
        "# geometrías simplificadas (~200 m) para aligerar el HTML interactivo\n",
        "g4326[\"geometry\"] = g4326.geometry.simplify(0.002, preserve_topology=True)\n",
        "g4326[\"p6_r\"] = g4326[\"p6\"].round(1)\n",
        "g4326[\"p6_eb_r\"] = g4326[\"p6_eb\"].round(1)\n",
        "g4326[\"den_r\"] = g4326[\"den_6m\"].astype(int)\n",
        "m = folium.Map(location=[-33.45, -70.66], zoom_start=5, tiles=\"cartodbpositron\")\n",
        "\n",
        "vmin, vmax = g4326[\"p6_eb\"].quantile([0.02, 0.98])\n",
        "cmap_fol = bcm.LinearColormap(SEQ_STEPS, vmin=vmin, vmax=vmax,\n",
        "                              caption=f\"LME al 6.º mes (%, tasas EB, {ULTIMO_COMPLETO})\")\n",
        "\n",
        "folium.GeoJson(\n",
        "    g4326[[\"IdComuna\", \"Comuna\", \"Region\", \"p6_r\", \"p6_eb_r\", \"den_r\", \"lisa\",\n",
        "           \"geometry\"]],\n",
        "    name=f\"LME₆ {ULTIMO_COMPLETO} (EB)\",\n",
        "    style_function=lambda f: {\n",
        "        \"fillColor\": cmap_fol(f[\"properties\"][\"p6_eb_r\"]),\n",
        "        \"color\": \"white\", \"weight\": 0.4, \"fillOpacity\": 0.85},\n",
        "    tooltip=folium.GeoJsonTooltip(\n",
        "        fields=[\"Comuna\", \"Region\", \"p6_r\", \"p6_eb_r\", \"den_r\", \"lisa\"],\n",
        "        aliases=[\"Comuna\", \"Región\", \"LME₆ cruda (%)\", \"LME₆ EB (%)\",\n",
        "                 \"Controles 6.º mes\", \"Clúster LISA (p≤0,05)\"],\n",
        "        localize=True),\n",
        ").add_to(m)\n",
        "\n",
        "capa_lisa = g4326[g4326[\"lisa\"] != \"ns\"][[\"IdComuna\", \"Comuna\", \"lisa\", \"geometry\"]]\n",
        "if len(capa_lisa):\n",
        "    folium.GeoJson(\n",
        "        capa_lisa,\n",
        "        name=\"Clústeres LISA (p ≤ 0,05)\",\n",
        "        style_function=lambda f: {\n",
        "            \"fillColor\": COL_LISA[f[\"properties\"][\"lisa\"]],\n",
        "            \"color\": \"white\", \"weight\": 0.4, \"fillOpacity\": 0.9},\n",
        "        tooltip=folium.GeoJsonTooltip(fields=[\"Comuna\", \"lisa\"],\n",
        "                                      aliases=[\"Comuna\", \"Clúster\"]),\n",
        "        show=False,\n",
        "    ).add_to(m)\n",
        "\n",
        "cmap_fol.add_to(m)\n",
        "folium.LayerControl(collapsed=False).add_to(m)\n",
        "\n",
        "# escritura robusta: primero a disco local, luego copia con reintentos\n",
        "# (la carpeta del proyecto vive en un sistema de archivos de Google Drive\n",
        "# que ocasionalmente agota el tiempo de escrituras grandes)\n",
        "import tempfile, time as _time\n",
        "\n",
        "ruta_mapa = OUT / \"mapa_interactivo_lme6_lisa.html\"\n",
        "with tempfile.NamedTemporaryFile(suffix=\".html\", delete=False) as tmpf:\n",
        "    tmp_html = Path(tmpf.name)\n",
        "m.save(str(tmp_html))\n",
        "contenido = tmp_html.read_bytes()\n",
        "tmp_html.unlink()\n",
        "for intento in range(3):\n",
        "    try:\n",
        "        ruta_mapa.write_bytes(contenido)\n",
        "        break\n",
        "    except OSError:\n",
        "        if intento == 2:\n",
        "            raise\n",
        "        _time.sleep(5)\n",
        "nota(f\"Mapa interactivo guardado en `{ruta_mapa.relative_to(RAIZ)}` \"\n",
        "     f\"({len(contenido) / 1048576:.1f} MB).\")"
      ],
      "id": "folium",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "El mapa interactivo (tasas EB con *tooltip* comunal y capa de clústeres LISA) queda\n",
        "disponible en `output_files/stage4/mapa_interactivo_lme6_lisa.html`.\n",
        "\n",
        "# Discusión\n",
        "\n",
        "Los resultados principales de la serie 2009–2026 pueden sintetizarse en siete hallazgos:\n",
        "\n",
        "1. **Trayectoria nacional**: la serie tiene dos regímenes separados por el quiebre\n",
        "   estructural de 2015 (44–45 % → ascenso sostenido hasta ~62 % en 2019); el ITS sobre\n",
        "   el régimen post-quiebre cuantifica la **interrupción asociada a la pandemia**\n",
        "   (caída de nivel y cambio de pendiente en marzo 2020) y la ausencia de recuperación\n",
        "   posterior. Esta estimación no es un efecto causal puro: la caída de ~37 % del\n",
        "   denominador de controles en 2020 implica selección de la subpoblación asistente, y\n",
        "   el contrafactual es una extrapolación lineal del régimen 2015–2019.\n",
        "2. **Heterogeneidad territorial persistente**: la autocorrelación espacial global es\n",
        "   positiva y significativa en prácticamente toda la serie, lo que indica que la LME no\n",
        "   se distribuye aleatoriamente en el territorio, sino en macro-zonas de alta y baja\n",
        "   prevalencia.\n",
        "3. **Clústeres estables**: con el criterio convencional (p ≤ 0,05) los clústeres LISA\n",
        "   muestran hot spots y cold spots que reaparecen año tras año (2019–2024); bajo el\n",
        "   criterio conservador FDR solo un núcleo reducido de comunas permanece significativo\n",
        "   en 2024, lo que acota la evidencia de clusterización local fuerte. La matriz de\n",
        "   transición de terciles evidencia una marcada inercia de rango: la mayoría de las\n",
        "   comunas permanece en su tercil de origen tras más de una década.\n",
        "4. **Desigualdad y convergencia**: los índices de Gini y Theil documentan el nivel y la\n",
        "   evolución de la desigualdad territorial; la descomposición del Theil indica cuánto\n",
        "   de ella se explica entre regiones versus dentro de ellas.\n",
        "5. **Brechas poblacionales**: la desagregación por sexo (2017–2022) muestra una\n",
        "   brecha pequeña y estable. Las columnas de pueblos originarios y migrantes (2021+)\n",
        "   exhiben heterogeneidad regional, pero sus denominadores están subregistrados y las\n",
        "   brechas cambian de signo según el tratamiento de las celdas inconsistentes: antes\n",
        "   que conclusiones de práctica de lactancia, son un llamado a mejorar la calidad del\n",
        "   registro grupal del REM para poder monitorear equidad.\n",
        "6. **La mejora histórica fue de retención, no de inicio**: la LME al 1.er mes\n",
        "   descendió a lo largo de la serie, mientras la razón de retención 6.º/1.er mes subió\n",
        "   hasta 2019 (con parte del salto concentrado en el quiebre de registro de 2015);\n",
        "   tras 2019 la retención se mantiene alta y el deterioro se concentra en el nivel\n",
        "   inicial. La lactancia continuada al año no es comparable a través de 2021 por la\n",
        "   re-codificación del formulario; su versión ampliada se mantiene estable. Las\n",
        "   díadas neonatales (2023+) agregan un punto de partida pre-primer mes para el\n",
        "   monitoreo futuro.\n",
        "7. **Composición**: desde 2021 la desagregación completa muestra el peso relativo de\n",
        "   la lactancia mixta y la fórmula al 6.º mes, y cuantifica el residuo «sin\n",
        "   clasificar» de las eras anteriores del formulario.\n",
        "\n",
        "# Limitaciones\n",
        "\n",
        "- **Denominadores administrativos**: las prevalencias se calculan sobre niños con\n",
        "  control de salud vigente en el sistema público (REM), no sobre cohortes\n",
        "  poblacionales; cambios en cobertura de control (p. ej., 2020) afectan numerador y\n",
        "  denominador simultáneamente.\n",
        "- **Cambios de formulario**: aunque el mapeo por año fue validado contra los\n",
        "  diccionarios oficiales, las definiciones operativas de registro pueden haber\n",
        "  cambiado sutilmente entre eras.\n",
        "- **Falacia ecológica y MAUP**: las asociaciones comunales no son inferencias\n",
        "  individuales, y los resultados espaciales dependen de la unidad de agregación.\n",
        "- **2025 en consolidación y 2026 preliminar**: se excluyeron de modelos e inferencia.\n",
        "- **Contrafactual del ITS**: es una extrapolación lineal del régimen 2015–2019 a casi\n",
        "  cinco años; la brecha estimada respecto de lo observado debe leerse como orden de\n",
        "  magnitud, con incertidumbre creciente en el horizonte.\n",
        "- **Calidad del registro**: existen varios miles de celdas indicador×comuna-mes con\n",
        "  numerador mayor que el denominador (recuento exacto reportado en el chunk de\n",
        "  armonización; truncadas al denominador salvo en la sección de pueblos\n",
        "  originarios/migrantes, donde se excluyen de ambos lados), los denominadores\n",
        "  grupales de pueblos originarios y migrantes están sustancialmente subregistrados\n",
        "  respecto de sus numeradores, y el shapefile presenta huecos de topología que se\n",
        "  sanearon con un buffer de tolerancia. Todo ello se documenta y trata\n",
        "  explícitamente, pero recuerda que el REM es un registro administrativo con errores\n",
        "  de origen.\n",
        "- Las columnas de pueblos originarios y migrantes no se desagregan por edad de\n",
        "  control, por lo que sus prevalencias no son estrictamente comparables con LME₆.\n",
        "\n",
        "# Referencias\n",
        "\n",
        "- Anselin, L. (1995). Local Indicators of Spatial Association—LISA. *Geographical Analysis*, 27(2), 93–115.\n",
        "- Bernal, J. L., Cummins, S., & Gasparrini, A. (2017). Interrupted time series regression for the evaluation of public health interventions. *International Journal of Epidemiology*, 46(1), 348–355.\n",
        "- Caldas de Castro, M., & Singer, B. (2006). Controlling the false discovery rate: a new application to account for multiple and dependent tests in local statistics of spatial association. *Geographical Analysis*, 38(2), 180–208.\n",
        "- Killick, R., Fearnhead, P., & Eckley, I. A. (2012). Optimal detection of changepoints with a linear computational cost. *JASA*, 107(500), 1590–1598.\n",
        "- Marshall, R. J. (1991). Mapping disease and mortality rates using empirical Bayes estimators. *Applied Statistics*, 40(2), 283–294.\n",
        "- Ministerio de Salud de Chile. Manuales de las Series REM 2009–2026. DEIS.\n",
        "- Rey, S. J., & Anselin, L. (2010). PySAL: A Python library of spatial analytical methods. En *Handbook of Applied Spatial Analysis*. Springer.\n",
        "- Víctora, C. G., et al. (2016). Breastfeeding in the 21st century. *The Lancet*, 387(10017), 475–490.\n",
        "\n",
        "# Anexo: armonización de columnas por año {#sec-anexo}"
      ],
      "id": "092398f4"
    },
    {
      "cell_type": "code",
