      "source": [
        "#| label: anexo-mapeo\n",
        "#| code-summary: Tabla de armonización columna→significado (LME, A0200002)\n",
        "#| tbl-cap: Columnas del código A0200002 (LME) usadas por año y edad de control, según los diccionarios oficiales DEIS.\n",
        "filas_anexo = []\n",
        "for anio_str, info in sorted(mapeo.items()):\n",
        "    cfg = info[\"codigos\"].get(COD_LME, {})\n",
        "    fila = {\"Año\": anio_str, \"Archivo diccionario\": info[\"_archivo\"]}\n",
        "    for e in EDADES:\n",
        "        fila[ETIQ_EDAD[e]] = \"+\".join(cfg.get(\"edad_cols\", {}).get(e, [])) or \"—\"\n",
        "    fila[\"P. originarios\"] = \"+\".join(cfg.get(\"po_cols\", [])) or \"—\"\n",
        "    fila[\"Migrantes\"] = \"+\".join(cfg.get(\"mig_cols\", [])) or \"—\"\n",
        "    filas_anexo.append(fila)\n",
        "boton_tabla(pd.DataFrame(filas_anexo).set_index(\"Año\"), \"anexo_mapeo_columnas\")"
      ],
      "id": "anexo-mapeo",
      "execution_count": null,
      "outputs": []
    },
